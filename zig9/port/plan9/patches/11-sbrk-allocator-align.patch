--- a/lib/std/heap/sbrk_allocator.zig
+++ b/lib/std/heap/sbrk_allocator.zig
@@ -164,6 +164,17 @@
                 big_frees[class] = node.*;
                 return top_free_ptr;
             }
+            // `sbrk` only guarantees page alignment, but a big slot must be aligned
+            // to its own (power-of-two) size: callers like `DebugAllocator` recover
+            // a slot's base by masking (`addr & ~(slot_size-1)`), and the small
+            // buckets tiled inside a bigpage inherit this base's alignment. Burn the
+            // break up to `slot_size_bytes` before claiming the slot.
+            // ponytail: wastes <slot_size_bytes once per size class; the break then
+            // stays aligned for same-size slots.
+            const cur = sbrk(0);
+            if (cur == 0) return 0;
+            const pad = mem.alignForward(usize, cur, slot_size_bytes) - cur;
+            if (pad != 0 and sbrk(pad) == 0) return 0;
             return sbrk(pow2_pages * pages_per_bigpage * heap.pageSize());
         }
     };
