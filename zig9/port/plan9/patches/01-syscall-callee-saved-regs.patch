--- a/lib/std/os/plan9/x86_64.zig
+++ b/lib/std/os/plan9/x86_64.zig
@@ -1,21 +1,59 @@
 const plan9 = @import("../plan9.zig");
-// TODO better inline asm
 
+// zig9: the Plan 9 amd64 kernel SYSCALL does not preserve the SysV callee-saved
+// registers (cc9 proved on hardware that rbx, rbp, r13 come back holding KZERO
+// kernel addresses). The self-hosted x86_64 backend likes to keep the base
+// register it uses to reach globals/externs in a callee-saved register — often
+// rbp — across calls. If a syscall trashes that register, the next global access
+// faults reading a 0xffffffff8… address. QEMU preserves the registers, so this
+// only bites on real hardware.
+//
+// Two things were required to fix it robustly:
+//   1) Do NOT pass the syscall number via a "{rbp}" input constraint. Doing so
+//      forces the compiler to spill/reload whatever lived in rbp around the asm,
+//      and the 0.14.1 backend gets that wrong — the global base is lost. Instead
+//      take the number in rdx and move it into rbp *inside* the asm.
+//   2) Explicitly push/pop every callee-saved register (rbp, rbx, r12-r15)
+//      around the SYSCALL in the asm body — like cc9's n9syscall.s — rather than
+//      relying on the clobber list, which the backend does not honor here. Since
+//      we save/restore them, they are NOT listed as clobbers, so the compiler is
+//      free to (and does) keep the global base in rbp across the call.
+
 pub fn syscall1(sys: plan9.SYS, arg0: usize) usize {
     return asm volatile (
+        \\push %%rbp
+        \\push %%rbx
+        \\push %%r12
+        \\push %%r13
+        \\push %%r14
+        \\push %%r15
+        \\movq %%rdx, %%rbp
         \\push %%r8
         \\push $0
         \\syscall
         \\pop %%r11
         \\pop %%r11
+        \\pop %%r15
+        \\pop %%r14
+        \\pop %%r13
+        \\pop %%r12
+        \\pop %%rbx
+        \\pop %%rbp
         : [ret] "={rax}" (-> usize),
         : [arg0] "{r8}" (arg0),
-          [syscall_number] "{rbp}" (@intFromEnum(sys)),
-        : "rcx", "rax", "rbp", "r11", "memory"
+          [syscall_number] "{rdx}" (@intFromEnum(sys)),
+        : "rcx", "rax", "rdx", "r11", "memory"
     );
 }
