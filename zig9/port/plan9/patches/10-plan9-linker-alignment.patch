+
+/// Insert alignment padding into the segment being written so the next atom's
+/// virtual address (`base + seg_i`) is a multiple of `alignment`. Padding bytes
+/// come from `pad_buf` (zeroed; never executed — functions end in `ret`, so text
+/// gaps are dead). Appends one iovec, advances the segment offset, and bumps the
+/// padding count so the iovec-count assert in flushModule stays exact.
+/// ponytail: pad capped at pad_buf.len (a page); alignments > 4096 aren't honored.
+fn padSegment(
+    iovecs: []std.posix.iovec_const,
+    iovecs_i: *usize,
+    seg_i: *u64,
+    base: u64,
+    alignment: u64,
+    pad_buf: []const u8,
+    n_pad: *usize,
+) void {
+    if (alignment <= 1) return;
+    const cur = base + seg_i.*;
+    const pad = mem.alignForward(u64, cur, alignment) - cur;
+    if (pad == 0) return;
+    const p: usize = @intCast(@min(pad, pad_buf.len));
+    iovecs[iovecs_i.*] = .{ .base = pad_buf.ptr, .len = p };
+    iovecs_i.* += 1;
+    seg_i.* += p;
+    n_pad.* += 1;
 }
 
