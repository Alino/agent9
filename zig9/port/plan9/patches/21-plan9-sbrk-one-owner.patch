+// zig9: under the CBE (the compiler-on-9front build) this code shares the
+// process with cc9's n9libc, whose malloc keeps its own break cursor — ALSO
+// rooted at `end`. Two independent cursors hand out overlapping memory and
+// corrupt both heaps (the source of the "latent heap corruption" family). The
+// break must have exactly one owner: delegate to cc9's locked sbrk. Native-
+// backend programs (no libc underneath) keep the local cursor below.
+extern fn cc9_sbrk(incr: isize) ?*anyopaque;
+
 pub fn sbrk(n: usize) usize {
+    if (builtin.zig_backend == .stage2_c) {
+        // Exact sbrk semantics: grant n bytes, return the region's start (the
+        // old break). SbrkAllocator does its own alignment burning, so no
+        // rounding here — a rounded return would misstate where the grant is.
+        const r = cc9_sbrk(@bitCast(n));
+        if (@intFromPtr(r) == std.math.maxInt(usize)) return 0; // (void*)-1
+        return @intFromPtr(r);
+    }
     if (bloc == 0) {
