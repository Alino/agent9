+// zig9: Plan 9 has no fork/CLOEXEC/execvpe; spawn over rfork(RFPROC|RFFDG|RFREND)
+// + exec, wiring .Pipe stdio through plan9 pipe()s and dup2. Spawn errors (a bad
+// exec) surface at wait() as a nonzero term rather than via an errpipe — Plan 9
+// has no atomic close-on-exec to build one. env_map is ignored: children inherit
+// the /env namespace group (zig build passes lib/cache dirs as args, not env).
+fn spawnPlan9(self: *ChildProcess) SpawnError!void {
+    const p9 = std.os.plan9;
+    const Pipe = struct {
+        fds: [2]i32 = .{ -1, -1 },
+        active: bool = false,
+        fn open(behavior: StdIo) !@This() {
+            if (behavior != .Pipe) return .{};
+            var self_: @This() = .{ .active = true };
+            if (@as(isize, @bitCast(p9.pipe(&self_.fds))) < 0) return error.SystemResources;
+            return self_;
+        }
+        fn closeBoth(self_: @This()) void {
+            if (self_.active) {
+                _ = p9.close(self_.fds[0]);
+                _ = p9.close(self_.fds[1]);
+            }
+        }
+    };
+
+    const stdin_pipe = try Pipe.open(self.stdin_behavior);
+    errdefer stdin_pipe.closeBoth();
+    const stdout_pipe = try Pipe.open(self.stdout_behavior);
+    errdefer stdout_pipe.closeBoth();
+    const stderr_pipe = try Pipe.open(self.stderr_behavior);
+    errdefer stderr_pipe.closeBoth();
+
+    var arena_allocator = std.heap.ArenaAllocator.init(self.allocator);
+    defer arena_allocator.deinit();
+    const arena = arena_allocator.allocator();
+    const argv_buf = try arena.allocSentinel(?[*:0]const u8, self.argv.len, null);
+    for (self.argv, 0..) |arg, i| argv_buf[i] = (try arena.dupeZ(u8, arg)).ptr;
+
+    const pid_result = p9.rfork(p9.RFPROC | p9.RFFDG | p9.RFREND);
+    const spid: isize = @bitCast(pid_result);
+    if (spid < 0) return error.SystemResources;
+    if (spid == 0) {
+        // Child: the RFFDG copy of the fd table has both ends of every pipe.
+        // dup the child-side end onto 0/1/2, then close ALL pipe fds so the
+        // parent's read ends see EOF when the child exits.
+        setUpChildIoPlan9(self.stdin_behavior, stdin_pipe.fds[0], 0);
+        setUpChildIoPlan9(self.stdout_behavior, stdout_pipe.fds[1], 1);
+        setUpChildIoPlan9(self.stderr_behavior, stderr_pipe.fds[1], 2);
+        stdin_pipe.closeBoth();
+        stdout_pipe.closeBoth();
+        stderr_pipe.closeBoth();
+        if (self.cwd) |cwd| {
+            var buf: [std.fs.max_path_bytes]u8 = undefined;
+            const cwd_z = std.fmt.bufPrintZ(&buf, "{s}", .{cwd}) catch p9.exits("cwd");
+            if (@as(isize, @bitCast(p9.chdir(cwd_z.ptr))) < 0) p9.exits("chdir");
+        } else if (self.cwd_dir) |cwd_dir| {
+            if (@as(isize, @bitCast(p9.fchdir(cwd_dir.fd))) < 0) p9.exits("fchdir");
+        }
+        // Plan 9 exec needs a resolvable path; retry via /bin for a bare name.
+        const arg0 = argv_buf[0].?;
+        _ = p9.exec(arg0, @ptrCast(argv_buf.ptr));
+        if (std.mem.indexOfScalar(u8, std.mem.span(arg0), '/') == null) {
+            var pb: [std.fs.max_path_bytes]u8 = undefined;
+            const p = std.fmt.bufPrintZ(&pb, "/bin/{s}", .{std.mem.span(arg0)}) catch p9.exits("exec");
+            _ = p9.exec(p.ptr, @ptrCast(argv_buf.ptr));
+        }
+        p9.exits("exec failed");
+    }
+
+    // Parent: keep our ends, close the child's ends.
+    errdefer comptime unreachable;
+    const pid: i32 = @intCast(spid);
+    self.stdin = if (self.stdin_behavior == .Pipe) .{ .handle = stdin_pipe.fds[1] } else null;
+    self.stdout = if (self.stdout_behavior == .Pipe) .{ .handle = stdout_pipe.fds[0] } else null;
+    self.stderr = if (self.stderr_behavior == .Pipe) .{ .handle = stderr_pipe.fds[0] } else null;
+    if (self.stdin_behavior == .Pipe) _ = p9.close(stdin_pipe.fds[0]);
+    if (self.stdout_behavior == .Pipe) _ = p9.close(stdout_pipe.fds[1]);
+    if (self.stderr_behavior == .Pipe) _ = p9.close(stderr_pipe.fds[1]);
+    self.id = pid;
+    self.term = null;
+}
+
+fn setUpChildIoPlan9(behavior: StdIo, pipe_fd: i32, target: i32) void {
+    const p9 = std.os.plan9;
+    switch (behavior) {
+        .Pipe => _ = p9.dup2(pipe_fd, target),
+        .Close => _ = p9.close(target),
+        .Ignore => {
+            const nf = p9.openMode("/dev/null", 2, 0); // ORDWR
+            if (@as(isize, @bitCast(nf)) >= 0) {
+                _ = p9.dup2(@intCast(nf), target);
+                _ = p9.close(@intCast(nf));
+            }
+        },
+        .Inherit => {}, // already inherited via RFFDG
+    }
+}
