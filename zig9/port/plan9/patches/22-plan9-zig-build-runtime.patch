+// zig9: back the plan9 single-threaded compiler heap with cc9's malloc/free
+// (n9libc — the same heap that runs rustc and CPython on 9front) instead of the
+// std sbrk page allocator, whose free-list corrupts under the heavy allocation
+// load of compiling the build runner in-process (a GP fault in SbrkAllocator.free).
+// cc9 malloc only guarantees 16-byte alignment, so over-allocate and stash the
+// raw pointer just below the aligned one. resize never grows in place (returns
+// false -> the caller reallocs via alloc+copy+free, so ZeroAllocator zeroes the
+// new block); this keeps it simple and correct at a small perf cost.
+const Cc9Allocator = struct {
+    extern fn malloc(n: usize) ?*anyopaque;
+    extern fn free(p: ?*anyopaque) void;
+    // Two stash words below every aligned pointer: [raw malloc ptr][magic ^ raw].
+    // The magic makes header corruption (the scale-dependent plan9 mystery)
+    // observable: a trashed header logs and leaks that one block instead of
+    // handing cc9's free() a wild pointer and GP-faulting the compile.
+    const hdr = 2 * @sizeOf(usize);
+    const magic: usize = 0x5A17C0DE_9F9F600D;
+    var bad_free_count: usize = 0;
+    fn allocator() std.mem.Allocator {
+        return .{ .ptr = undefined, .vtable = &.{
+            .alloc = alloc,
+            .resize = resize,
+            .remap = remap,
+            .free = freeFn,
+        } };
+    }
+    fn alloc(_: *anyopaque, len: usize, a: std.mem.Alignment, _: usize) ?[*]u8 {
+        const alignb = a.toByteUnits();
+        const raw = malloc(len + alignb + hdr) orelse return null;
+        const base = @intFromPtr(raw) + hdr;
+        const aligned = std.mem.alignForward(usize, base, alignb);
+        const store: *[2]usize = @ptrFromInt(aligned - hdr);
+        store[0] = @intFromPtr(raw);
+        store[1] = magic ^ @intFromPtr(raw);
+        return @ptrFromInt(aligned);
+    }
+    fn resize(_: *anyopaque, buf: []u8, _: std.mem.Alignment, new_len: usize, _: usize) bool {
+        return new_len <= buf.len;
+    }
+    fn remap(_: *anyopaque, buf: []u8, _: std.mem.Alignment, new_len: usize, _: usize) ?[*]u8 {
+        return if (new_len <= buf.len) buf.ptr else null;
+    }
+    fn freeFn(_: *anyopaque, buf: []u8, _: std.mem.Alignment, _: usize) void {
+        // A GP fault here means the CALLER passed a wild (non-canonical)
+        // pointer — corruption upstream of the allocator. Log the raw value
+        // (its bit pattern fingerprints the owner) instead of dereferencing.
+        const p = @intFromPtr(buf.ptr);
+        if (p < 0x200000 or p >= 0x8000000000 or (p & (@sizeOf(usize) - 1)) != 0) {
+            bad_free_count += 1;
+            if (bad_free_count <= 8) {
+                // walk the rbp chain (clang -O0 keeps frame pointers) so the
+                // caller can be symbolized offline against zig9big.elf
+                var ra: [6]usize = @splat(0);
+                var fp = @frameAddress();
+                for (&ra) |*slot| {
+                    if (fp < 0x1000 or fp >= 0x8000000000 or (fp & 7) != 0) break;
+                    const frame: *const [2]usize = @ptrFromInt(fp);
+                    slot.* = frame[1];
+                    if (frame[0] <= fp) break;
+                    fp = frame[0];
+                }
+                std.log.err("cc9alloc: WILD free #{d}: ptr=0x{x} len={d} bt=0x{x},0x{x},0x{x},0x{x},0x{x},0x{x}", .{
+                    bad_free_count, p, buf.len, ra[0], ra[1], ra[2], ra[3], ra[4], ra[5],
+                });
+            }
+            return;
+        }
+        const store: *const [2]usize = @ptrFromInt(@intFromPtr(buf.ptr) - hdr);
+        const raw = store[0];
+        if (store[1] != magic ^ raw or raw == 0 or raw >= @intFromPtr(buf.ptr)) {
+            // Header trashed (the scale-dependent corruption this diagnostic
+            // exists to profile): leak this one block and report it rather
+            // than GP-faulting the whole compile.
+            bad_free_count += 1;
+            if (bad_free_count <= 8) {
+                std.log.err("cc9alloc: corrupted header at free #{d}: ptr=0x{x} len={d} stash=[0x{x}, 0x{x}]", .{
+                    bad_free_count, @intFromPtr(buf.ptr), buf.len, raw, store[1],
+                });
+            }
+            return;
+        }
+        free(@ptrFromInt(raw));
+    }
+};
 
