+// Plan 9 has no cross-directory rename (wstat renames a leaf in place), and its
+// std.fs.Dir.walk/deleteTree misbehave over 9P (entries shift while deleting),
+// so move a tree by recursive copy + delete with names snapshotted up front.
+// Mirrors the helpers in src/Compilation.zig / src/Package/Fetch.zig.
+fn plan9DirNames(gpa: std.mem.Allocator, d: fs.Dir) std.ArrayListUnmanaged([]u8) {
+    var names: std.ArrayListUnmanaged([]u8) = .{};
+    var it = d.iterate();
+    while (it.next() catch null) |e| {
+        const dup = gpa.dupe(u8, e.name) catch continue;
+        names.append(gpa, dup) catch gpa.free(dup);
+    }
+    return names;
+}
+fn plan9RmTree(gpa: std.mem.Allocator, parent: fs.Dir, name: []const u8) void {
+    const st = parent.statFile(name) catch {
+        parent.deleteFile(name) catch {};
+        return;
+    };
+    if (st.kind != .directory) {
+        parent.deleteFile(name) catch {};
+        return;
+    }
+    var d = parent.openDir(name, .{ .iterate = true }) catch return;
+    var names = plan9DirNames(gpa, d);
+    for (names.items) |nm| plan9RmTree(gpa, d, nm);
+    for (names.items) |nm| gpa.free(nm);
+    names.deinit(gpa);
+    d.close();
+    parent.deleteDir(name) catch {};
+}
+fn plan9CopyTree(gpa: std.mem.Allocator, sdir: fs.Dir, spath: []const u8, ddir: fs.Dir, dpath: []const u8) !void {
+    try ddir.makePath(dpath);
+    var s = try sdir.openDir(spath, .{ .iterate = true });
+    var names = plan9DirNames(gpa, s);
+    s.close();
+    defer {
+        for (names.items) |nm| gpa.free(nm);
+        names.deinit(gpa);
+    }
+    for (names.items) |nm| {
+        var b1: [fs.max_path_bytes]u8 = undefined;
+        var b2: [fs.max_path_bytes]u8 = undefined;
+        const sp = try std.fmt.bufPrint(&b1, "{s}/{s}", .{ spath, nm });
+        const dp = try std.fmt.bufPrint(&b2, "{s}/{s}", .{ dpath, nm });
+        const cst = sdir.statFile(sp) catch continue;
+        switch (cst.kind) {
+            .directory => try plan9CopyTree(gpa, sdir, sp, ddir, dp),
+            else => try sdir.copyFile(sp, ddir, dp, .{}),
+        }
+    }
+}
+fn plan9MoveTree(gpa: std.mem.Allocator, dir: fs.Dir, src: []const u8, dst: []const u8) !void {
+    plan9RmTree(gpa, dir, dst);
+    errdefer plan9RmTree(gpa, dir, dst);
+    try plan9CopyTree(gpa, dir, src, dir, dst);
+    plan9RmTree(gpa, dir, src);
+}
