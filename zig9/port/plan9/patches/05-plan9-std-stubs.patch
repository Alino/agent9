+// zig9: minimal stubs so std.posix's `system.X` aliases resolve on plan9. Plan 9
+// has no tty(2)/ucontext concept; these exist so that the large fraction of the
+// standard library (and the upstream behavior tests) that transitively pulls in
+// std.posix / std.debug will compile. None are used at runtime by those tests.
+// `isatty` returns 0 (not a terminal) to match std.posix's `!= 0` check.
+pub fn isatty(fd: i32) c_int {
+    _ = fd;
+    return 0;
+}
