+pub fn munmap(ptr: [*]const u8, len: usize) usize {
+    _ = ptr;
+    _ = len;
+    return 0;
+}
+pub fn msync(ptr: [*]const u8, len: usize, flags: i32) usize {
+    _ = ptr;
+    _ = len;
