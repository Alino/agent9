+    return 0;
+}
+// No writev(2) on Plan 9 — emulate over write(2), stopping on error/short write.
+pub fn writev(fd: i32, iov: [*]const std.posix.iovec_const, count: usize) usize {
+    var total: usize = 0;
+    var i: usize = 0;
+    while (i < count) : (i += 1) {
+        const n = write(fd, iov[i].base, iov[i].len);
+        if (@as(isize, @bitCast(n)) < 0) return n;
+        total += n;
+        if (n != iov[i].len) break;
+    }
+    return total;
+}
