+    // zig9: a near call/jmp target register is always 64-bit in long mode. The
+    // Select patterns reference the (symbol) target temp at dword size — harmless
+    // for elf/macho (the target lowers to a rel32 immediate), but on plan9 the
+    // lazy symbol is materialized into a register, yielding `call r32`, which has
+    // no encoding. Promote a register call/jmp target to 64-bit here.
+    switch (emit_mnemonic) {
+        .call, .jmp => if (emit_ops.len > 0) switch (emit_ops[0]) {
+            .reg => |r| emit_ops[0] = .{ .reg = r.to64() },
+            else => {},
+        },
+        else => {},
     }
     lower.result_insts[lower.result_insts_len] = try .new(emit_prefix, emit_mnemonic, emit_ops, lower.target);
     lower.result_insts_len += 1;
