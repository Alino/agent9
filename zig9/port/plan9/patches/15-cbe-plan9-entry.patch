+fn plan9CcMain(c_argc: c_int, c_argv: [*][*:0]c_char) callconv(.c) c_int {
+    // zig9 (plan9 + ofmt=c only): cc9's crt0 already captured the Plan 9 Tos
+    // pointer (entry rax) and built a NAME=value environ from /env before
+    // calling main. __cc9_tos itself is unreachable from Zig (the CBE mangles
+    // leading-__ extern names), so it comes through a zig9compat.c accessor.
+    const zig9_tos = @extern(*const fn () callconv(.c) *std.os.plan9.Tos, .{ .name = "zig9_tos" });
+    std.os.plan9.tos = zig9_tos();
+    const c_envp = @extern(*[*:null]?[*:0]u8, .{ .name = "environ" }).*;
+    var env_count: usize = 0;
+    while (c_envp[env_count] != null) : (env_count += 1) {}
+    const envp = @as([*][*:0]u8, @ptrCast(c_envp))[0..env_count];
+    return callMainWithArgs(@intCast(c_argc), @ptrCast(c_argv), envp);
