+// Truncate via wstat setting the length field; a Twstat with every other field
+// "don't touch" (0xff / empty). // ponytail: builds the minimal 9P stat inline;
+// only length is set, all other fields left as no-change sentinels.
+pub fn ftruncate(fd: i32, length: u64) usize {
+    // Twstat setting only length: body = 39 fixed fields + 4 empty strings (8).
+    var st: [49]u8 = [_]u8{0} ** 49;
+    const body_len: u16 = 39 + 8; // 47
+    std.mem.writeInt(u16, st[0..2], body_len, .little);
+    @memset(st[2..33], 0xff); // type..mtime (31 bytes) = "don't touch"
+    std.mem.writeInt(u64, st[33..41], length, .little);
+    // name/uid/gid/muid empty strings (count 0) already zeroed at 41..49
+    const rc = syscall_bits.syscall3(.FWSTAT, @bitCast(@as(isize, fd)), @intFromPtr(&st), body_len + 2);
+    return if (@as(isize, @bitCast(rc)) < 0) errnoNeg() else 0;
+}
