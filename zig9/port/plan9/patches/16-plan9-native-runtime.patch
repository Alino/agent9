+// Reaped waitmsgs for children other than the one being waited on. Plan 9's
+// AWAIT can't re-deliver a status, so stash mismatches here (mirrors cc9's ztab).
+// ponytail: fixed 8-slot table; a build with >8 concurrent orphaned children
+// would drop the 9th — fine for the compiler's spawn pattern, grow if needed.
+var zombie_pid: [8]pid_t = [_]pid_t{0} ** 8;
+var zombie_status: [8]u32 = undefined;
+
+// Decode one AWAIT waitmsg: "pid utime stime rtime 'status'". The status field
+// is rc-quoted (%q): a clean exit is '' (empty quoted string), NOT literally
+// empty. Matches cc9's cc9_wait_decode (posix_llvm.c).
+fn decodeWait(msg: []const u8, out_status: *u32) ?pid_t {
+    var it = std.mem.tokenizeScalar(u8, msg, ' ');
+    const wpid_s = it.next() orelse return null;
+    const wpid = std.fmt.parseInt(pid_t, wpid_s, 10) catch return null;
+    _ = it.next(); // utime
+    _ = it.next(); // stime
+    _ = it.next(); // rtime
+    var st = it.rest();
+    if (st.len != 0 and st[0] == '\'') st = st[1..]; // skip opening quote
+    // '' or end -> clean exit 0. All-digits -> that exit code (Zig's plan9 exit
+    // writes a decimal status for nonzero). Anything else -> report as a signal.
+    if (st.len == 0 or st[0] == '\'') {
+        out_status.* = 0;
+    } else if (std.fmt.parseInt(u8, std.mem.sliceTo(st, '\''), 10)) |code| {
+        out_status.* = @as(u32, code) << 8; // WIFEXITED, WEXITSTATUS=code
+    } else |_| {
+        out_status.* = @intFromEnum(E.@"2BIG"); // non-zero TERMSIG -> WIFSIGNALED
+        out_status.* = 6; // SIGABRT-ish
+    }
+    return wpid;
+}
