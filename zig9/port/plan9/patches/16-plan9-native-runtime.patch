+// POSIX wait-status decoders. The plan9 Child arm (zig9) recovers exit codes
+// from await(2) text and never builds these ints, but posix.zig references the
+// type unconditionally, so provide the conventional encoding.
+pub const W = struct {
+    pub fn EXITSTATUS(s: u32) u8 {
+        return @intCast((s & 0xff00) >> 8);
+    }
+    pub fn TERMSIG(s: u32) u32 {
+        return s & 0x7f;
+    }
+    pub fn STOPSIG(s: u32) u32 {
+        return EXITSTATUS(s);
+    }
+    pub fn IFEXITED(s: u32) bool {
+        return TERMSIG(s) == 0;
+    }
+    pub fn IFSTOPPED(s: u32) bool {
+        return (s & 0xff) == 0x7f;
+    }
+    pub fn IFSIGNALED(s: u32) bool {
+        return (((s & 0x7f) + 1) >> 1) > 0;
+    }
+};
