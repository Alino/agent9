+fn decodeStat(wire: []const u8, st: *Stat) void {
+    const p9mode = std.mem.readInt(u32, wire[stat_mode..][0..4], .little);
+    const is_dir = (wire[stat_qidtype] & 0x80) != 0 or (p9mode & 0x80000000) != 0;
