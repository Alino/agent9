+// Wall clock via /dev/bintime (8 bytes big-endian ns since the Unix epoch) —
+// same source cc9's clock_gettime uses. Plan 9 has no separate monotonic
+// clock; the compiler only needs coarse elapsed time (Progress/Cache).
+pub fn nanosleep(req: *const timespec, rem: ?*timespec) usize {
+    if (rem) |r| r.* = .{};
+    const ms: usize = @intCast(@divTrunc(req.sec, 1) * 1000 + @divTrunc(req.nsec, 1_000_000));
