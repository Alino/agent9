+pub fn waitpid(pid: pid_t, status: *u32, flags: u32) usize {
+    // Serve a previously-stashed status for this pid first.
+    if (pid > 0) for (&zombie_pid, &zombie_status) |*zp, *zs| {
+        if (zp.* == pid) {
+            zp.* = 0;
+            status.* = zs.*;
+            return @intCast(pid);
+        }
+    };
+    var buf: [256]u8 = undefined;
+    while (true) {
+        const rc = syscall_bits.syscall2(.AWAIT, @intFromPtr(&buf), buf.len);
+        const n: isize = @bitCast(rc);
+        if (n < 0) return @bitCast(@as(isize, -1));
+        var st: u32 = 0;
+        const wpid = decodeWait(buf[0..@intCast(n)], &st) orelse continue;
+        if (pid > 0 and wpid != pid) {
+            // Not ours: stash it so a later waitpid(wpid) finds it.
+            for (&zombie_pid, &zombie_status) |*zp, *zs| {
+                if (zp.* == 0) {
+                    zp.* = wpid;
+                    zs.* = st;
+                    break;
+                }
+            }
+            if ((flags & 1) != 0) return 0; // WNOHANG: don't block re-reading
+            continue;
+        }
+        status.* = st;
+        return @intCast(wpid);
+    }
+}
