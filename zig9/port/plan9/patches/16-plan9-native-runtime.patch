+// Plan 9 signalling is note(2) via /proc/<pid>/note; std.posix.kill only needs
+// to compile for the shared Child code (the plan9 Child arm signals directly).
+pub fn kill(pid: pid_t, sig: u8) usize {
+    _ = sig;
+    var buf: [64]u8 = undefined;
+    const path = std.fmt.bufPrintZ(&buf, "/proc/{d}/note", .{pid}) catch return @bitCast(@as(isize, -1));
+    const fd = openMode(path.ptr, 1, 0); // OWRITE
+    if (@as(isize, @bitCast(fd)) < 0) return @bitCast(@as(isize, -1));
+    _ = write(@intCast(fd), "kill", 4);
+    _ = close(@intCast(fd));
+    return 0;
+}
