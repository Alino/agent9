+// zig9: resolve a dirfd-relative path to an absolute path (Plan 9 has no *at
+// syscalls; every dir-relative op joins the dir's fd2path with the sub-path).
+// Returns the absolute path written into `buf`, NUL-terminated.
+pub fn resolveAt(dirfd: i32, path: [*:0]const u8, buf: []u8) ?[:0]u8 {
+    const sub = std.mem.span(path);
+    if (dirfd == AT.FDCWD or (sub.len > 0 and sub[0] == '/')) {
+        if (sub.len + 1 > buf.len) return null;
+        @memcpy(buf[0..sub.len], sub);
+        buf[sub.len] = 0;
+        return buf[0..sub.len :0];
+    }
+    var dir_buf: [std.fs.max_path_bytes]u8 = undefined;
+    const rc = fd2path(dirfd, &dir_buf, dir_buf.len);
+    if (@as(isize, @bitCast(rc)) < 0) return null;
+    const dir = std.mem.span(@as([*:0]u8, @ptrCast(&dir_buf)));
+    var fba = std.heap.FixedBufferAllocator.init(buf);
+    const a = fba.allocator();
+    const joined = std.fs.path.joinZ(a, &.{ dir, sub }) catch return null;
+    return joined;
+}
