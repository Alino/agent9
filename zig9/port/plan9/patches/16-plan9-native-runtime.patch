+// zig9: Plan 9 syscalls return -1 and set an error *string*, not a POSIX errno.
+// std.posix.errno() expects a small negative -errno. Map the common errstr
+// phrases to the errno the shared std.fs code branches on (EEXIST for
+// makePath, ENOENT for open-missing, etc.) and return it as a small negative
+// value. Anything unrecognized becomes -EIO (a real, in-range errno) rather
+// than 0 (which errno() would read as success). // ponytail: substring match,
+// not the full errstr table — covers what the compiler's fs paths need.
+pub fn errnoNeg() usize {
+    const s = errstr();
+    const e: isize = if (containsAny(s, "already exists")) -@as(isize, @intFromEnum(E.EXIST)) else if (containsAny(s, "exist")) blk: {
