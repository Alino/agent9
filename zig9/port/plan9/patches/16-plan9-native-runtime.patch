+pub fn renameat(old_dirfd: i32, old_path: [*:0]const u8, new_dirfd: i32, new_path: [*:0]const u8) usize {
+    // Plan 9 rename = wstat the name field; it can only rename within the same
+    // directory (no move across dirs). Resolve both, require equal parents.
+    var obuf: [std.fs.max_path_bytes]u8 = undefined;
+    var nbuf: [std.fs.max_path_bytes]u8 = undefined;
+    const oabs = resolveAt(old_dirfd, old_path, &obuf) orelse return @bitCast(@as(isize, -1));
+    const nabs = resolveAt(new_dirfd, new_path, &nbuf) orelse return @bitCast(@as(isize, -1));
+    // Plan 9 rename = wstat name-change, SAME directory only. Report XDEV for a
+    // cross-dir move so std can fall back to copy+delete (see renameTmpIntoCache).
+    const odir = std.fs.path.dirname(oabs) orelse "/";
+    const ndir = std.fs.path.dirname(nabs) orelse "/";
+    if (!std.mem.eql(u8, odir, ndir)) return @bitCast(@as(isize, -@as(isize, @intFromEnum(E.XDEV))));
+    // zig9: under the CBE (native compiler) build, defer the same-dir case to
+    // cc9's proven rename() from n9libc — it does the Twstat name-change AND the
+    // POSIX remove-existing-target-then-retry that Plan 9 wstat-rename requires
+    // (bare wstat refuses if the target exists). The hand-rolled Twstat below
+    // works for the a.out cross path but is flakier across fs servers.
+    if (builtin.zig_backend == .stage2_c) {
+        const cc9_rename = @extern(*const fn ([*:0]const u8, [*:0]const u8) callconv(.c) c_int, .{ .name = "rename" });
+        const rc = cc9_rename(oabs.ptr, nabs.ptr);
+        return if (rc < 0) @bitCast(@as(isize, -@as(isize, @intFromEnum(E.EXIST)))) else 0;
+    }
+    const newname = std.fs.path.basename(nabs);
+    // Plan 9 names are bounded by NAMEMAX (28) / at most 255; a name that won't
+    // fit the Twstat buffer is not a valid target.
+    if (newname.len > 207) return @bitCast(@as(isize, -@as(isize, @intFromEnum(E.NAMETOOLONG))));
+    // Twstat: only the name field is set, everything else "don't touch".
+    // body_len counts the bytes AFTER the leading size[2]: 39 fixed fields
+    // (type..length) + name[2+len] + empty uid/gid/muid (2 each).
+    var st: [256]u8 = [_]u8{0} ** 256;
+    const namelen: u16 = @intCast(newname.len);
+    const body_len: u16 = 39 + 2 + namelen + 6;
+    std.mem.writeInt(u16, st[0..2], body_len, .little);
+    @memset(st[2..41], 0xff); // type..length (39 bytes) = no-change
+    std.mem.writeInt(u16, st[41..43], namelen, .little);
+    @memcpy(st[43 .. 43 + namelen], newname);
+    // uid/gid/muid empty strings (count 0) already zeroed
+    const rc = wstat(oabs.ptr, &st, body_len + 2);
+    return if (@as(isize, @bitCast(rc)) < 0) errnoNeg() else 0;
+}
