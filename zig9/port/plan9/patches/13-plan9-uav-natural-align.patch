+    // (data atoms are otherwise packed back-to-back). Floor it at the value's
+    // natural ABI alignment: an auto-generated const often arrives with
+    // explicit_alignment == .none, but e.g. a 16-byte vector used as a legacy-SSE
+    // memory operand (a @shuffle pshufb mask, or a spilled @Vector) GP-faults if
+    // it isn't naturally aligned.
+    const uav_ty = Type.fromInterned(pt.zcu.intern_pool.typeOf(uav));
+    const natural_align = uav_ty.abiAlignment(pt.zcu).toByteUnits() orelse 1;
+    const want_align = @max(explicit_alignment.toByteUnits() orelse 0, natural_align);
+    try self.uav_alignment.put(self.base.comp.gpa, uav, @intCast(want_align));
