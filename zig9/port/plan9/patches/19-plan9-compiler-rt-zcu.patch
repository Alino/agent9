Plan 9's a.out linker links only the zcu — a compiler-rt static library is
silently dropped, so compile compiler-rt INTO the zcu for plan9 (like Obj
builds). Exports must be strong even in test builds (internal = nothing to
resolve against). All float families are exported too — the linker's GC
(patch 20) sweeps whatever a program doesn't reference, so they cost
codegen time but no binary size; only the few f16 helpers the backend
cannot compile ("ran out of registers") stay gated per-function via
common.want_f16_helpers.

--- a/src/Compilation.zig
+++ b/src/Compilation.zig
@@ -1309,6 +1309,10 @@
             const want = options.want_compiler_rt orelse is_exe_or_dyn_lib;
             if (!want) break :s .none;
             if (have_zcu and output_mode == .Obj) break :s .zcu;
+            // zig9: the Plan 9 a.out linker links only the zcu — a compiler_rt
+            // static library would be silently dropped. Compile it into the zcu
+            // so libcalls (__divti3 & co) resolve as in-module exports.
+            if (have_zcu and options.root_mod.resolved_target.result.ofmt == .plan9) break :s .zcu;
             if (is_exe_or_dyn_lib) break :s .lib;
             break :s .obj;
         };
--- a/lib/compiler_rt.zig
+++ b/lib/compiler_rt.zig
@@ -31,6 +31,11 @@
     _ = @import("compiler_rt/subo.zig");
     _ = @import("compiler_rt/mulo.zig");
 
+    // Float routines: on plan9-stage2 these are compiled into the zcu like the
+    // rest of compiler-rt; the linker's GC sweeps whatever a program doesn't
+    // reference, so exporting them costs codegen time but no binary size. The
+    // few f16 helpers the backend cannot compile stay gated per-function via
+    // common.want_f16_helpers.
     // Float routines
     // conversion
     _ = @import("compiler_rt/extendf.zig");
--- a/lib/compiler_rt/common.zig
+++ b/lib/compiler_rt/common.zig
@@ -3,7 +3,12 @@
 const native_endian = builtin.cpu.arch.endian();
 const ofmt_c = builtin.object_format == .c;
 
-pub const linkage: std.builtin.GlobalLinkage = if (builtin.is_test)
+pub const linkage: std.builtin.GlobalLinkage = if (builtin.object_format == .plan9)
+    // Plan 9 compiles compiler-rt into the zcu (no separate lib to clash with,
+    // even in test builds) and resolves libcalls against zcu exports by name,
+    // so the symbols must be real (strong) exports unconditionally.
+    .strong
+else if (builtin.is_test)
     .internal
 else if (ofmt_c)
     .strong
@@ -51,6 +56,12 @@
 
 pub const want_float_exceptions = !builtin.cpu.arch.isWasm();
 
+/// The self-hosted x86_64 backend cannot yet compile a handful of f16
+/// soft-float helpers ("ran out of registers"). Plan 9 is the only target that
+/// links compiler-rt through that backend, so skip those exports there — f16
+/// arithmetic already doesn't work on plan9 (documented port limitation).
+pub const want_f16_helpers = !(builtin.zig_backend == .stage2_x86_64 and builtin.object_format == .plan9);
+
 // Libcalls that involve u128 on Windows x86-64 are expected by LLVM to use the
 // calling convention of @Vector(2, u64), rather than what's standard.
 pub const want_windows_v2u64_abi = builtin.os.tag == .windows and builtin.cpu.arch == .x86_64 and !ofmt_c;
