+/// Compute atom liveness from the `_start` entry export. Edges: `gc_edges`
+/// (code-side, recorded during codegen), `relocs` (data-side pointers), and
+/// named-global phantoms -> their same-named export's atom. Returns one bool
+/// per atom; caller frees. If no `_start` export exists (exotic outputs),
+/// everything is kept.
+fn gcMark(self: *Plan9, pt: Zcu.PerThread) ![]bool {
+    const gpa = self.base.comp.gpa;
+    const marks = try gpa.alloc(bool, self.atoms.items.len);
+    errdefer gpa.free(marks);
+    @memset(marks, false);
+
+    // reverse map for the phantom-global hop (atom -> name)
+    var global_names: std.AutoHashMapUnmanaged(Atom.Index, []const u8) = .empty;
+    defer global_names.deinit(gpa);
+    var git = self.globals.iterator();
+    while (git.next()) |g| try global_names.put(gpa, g.value_ptr.*, g.key_ptr.*);
+
+    var work: std.ArrayListUnmanaged(Atom.Index) = .empty;
+    defer work.deinit(gpa);
+
+    if (self.findExportAtom(pt, "_start")) |root| {
+        try work.append(gpa, root);
+    } else {
+        @memset(marks, true);
+        return marks;
+    }
+
+    while (work.pop()) |idx| {
+        if (marks[idx]) continue;
+        marks[idx] = true;
+        if (self.gc_edges.getPtr(idx)) |lst| {
+            for (lst.items) |t| if (!marks[t]) try work.append(gpa, t);
+        }
+        if (self.relocs.getPtr(idx)) |lst| {
+            for (lst.items) |r| switch (r.type) {
+                .pcrel, .nonpcrel => if (!marks[r.target]) try work.append(gpa, r.target),
+                else => {},
+            };
+        }
+        if (global_names.get(idx)) |name| {
+            // a live libcall keeps its in-module implementation alive
+            if (self.findExportAtom(pt, name)) |t| {
+                if (!marks[t]) try work.append(gpa, t);
+            }
+        }
+    }
+    return marks;
+}
