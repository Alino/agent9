+/// Get (or create) the phantom atom for a named external symbol. The returned
+/// atom has a GOT slot; its value is resolved against the zcu's exports at
+/// flush time. `lib_name` is meaningless on Plan 9 (fully static).
+pub fn getGlobalSymbol(self: *Plan9, name: []const u8, lib_name: ?[]const u8) !Atom.Index {
+    _ = lib_name;
+    if (self.globals.get(name)) |index| {
+        try self.gcEdge(index);
+        return index;
+    }
+    const gpa = self.base.comp.gpa;
+    const owned = try gpa.dupe(u8, name);
+    errdefer gpa.free(owned);
+    const index = try self.createAtom();
+    self.getAtomPtr(index).got_index = self.allocateGotIndex();
+    try self.globals.putNoClobber(gpa, owned, index);
+    try self.gcEdge(index);
+    return index;
+}
+
+/// Mark the start of `atom_idx`'s codegen: subsequent atom references recorded
+/// as its GC edges. Re-codegen of the same atom resets its edge list. Returns
+/// the previous codegen context — lazy-symbol codegen nests inside a function's
+/// codegen, so the caller must RESTORE (not clear) it when done.
+fn gcBegin(self: *Plan9, atom_idx: Atom.Index) ?Atom.Index {
+    if (!self.base.gc_sections) return null;
+    const prev = self.gc_current;
+    self.gc_current = atom_idx;
+    if (self.gc_edges.getPtr(atom_idx)) |lst| lst.clearRetainingCapacity();
+    return prev;
+}
+
+/// Record "the atom currently being codegen'd references `to`".
+fn gcEdge(self: *Plan9, to: Atom.Index) !void {
+    if (!self.base.gc_sections) return;
+    const from = self.gc_current orelse return;
+    if (from == to) return;
+    const gpa = self.base.comp.gpa;
+    const gop = try self.gc_edges.getOrPut(gpa, from);
+    if (!gop.found_existing) gop.value_ptr.* = .{};
+    try gop.value_ptr.append(gpa, to);
+}
+
+/// Find the atom of the zcu export named `name`, if any.
+fn findExportAtom(self: *Plan9, pt: Zcu.PerThread, name: []const u8) ?Atom.Index {
+    const ip = &pt.zcu.intern_pool;
+    var nit = self.nav_exports.iterator();
+    while (nit.next()) |ne| {
+        for (ne.value_ptr.*) |export_idx| {
+            const exp = export_idx.ptr(pt.zcu);
+            // deleteExport is a no-op for plan9 and the Zcu recycles
+            // Export.Index slots, so a stale entry here may now describe a
+            // different nav's export — trust it only if it still points back
+            // at the nav it is filed under.
+            if (exp.exported != .nav or exp.exported.nav != ne.key_ptr.*) continue;
+            if (exp.opts.name.eqlSlice(name, ip)) {
+                if (self.navs.get(ne.key_ptr.*)) |meta| return meta.index;
+                return null;
+            }
+        }
+    }
+    return null;
 }
