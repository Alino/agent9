+/// Get (or create) the phantom atom for a named external symbol. The returned
+/// atom has a GOT slot; its value is resolved against the zcu's exports at
+/// flush time. `lib_name` is meaningless on Plan 9 (fully static).
+pub fn getGlobalSymbol(self: *Plan9, name: []const u8, lib_name: ?[]const u8) !Atom.Index {
+    _ = lib_name;
+    if (self.globals.get(name)) |index| return index;
+    const gpa = self.base.comp.gpa;
+    const owned = try gpa.dupe(u8, name);
+    errdefer gpa.free(owned);
+    const index = try self.createAtom();
+    self.getAtomPtr(index).got_index = self.allocateGotIndex();
+    try self.globals.putNoClobber(gpa, owned, index);
+    return index;
+}
