+/// Get the GOT vaddr for a named external symbol (a libcall callee), allocating a
+/// slot on first use. The slot is filled at flush from the like-named export sym.
+/// The backend emits `call qword ptr ds:[addr]` against the returned address, just
+/// like a normal nav call.
+pub fn getExternGotAddr(self: *Plan9, name: []const u8) !u64 {
+    const gpa = self.base.comp.gpa;
+    const gop = try self.extern_got.getOrPut(gpa, name);
+    if (!gop.found_existing) {
+        gop.key_ptr.* = try gpa.dupe(u8, name);
+        gop.value_ptr.* = self.allocateGotIndex();
+    }
+    const target = self.base.comp.root_mod.resolved_target.result;
+    const ptr_bytes = @divExact(target.ptrBitWidth(), 8);
+    return self.bases.data + gop.value_ptr.* * ptr_bytes;
+}
