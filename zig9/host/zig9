#!/bin/bash
# zig9 — cross-compile a Zig source to a runnable 9front amd64 a.out (and run it).
#   zig9 build SRC [-Oopt]      compile -> /tmp/<src>.aout
#   zig9 run   SRC [-Oopt]      build, then deliver to a 9front box and run it
#
# Uses the vendored Zig 0.14.1 host toolchain with our PATCHED std lib
# (vendor/zig/lib via --zig-lib-dir) targeting x86_64-plan9 with the self-hosted
# x86_64 backend + Plan 9 a.out linker (no LLVM — LLVM cannot emit Plan 9 objs).
#
# Default optimize is ReleaseSmall: the 0.14.1 self-hosted x86_64 backend has a
# codegen bug in safety-on modes (Debug/ReleaseSafe -> "store: [direct:N]"
# compiler panic), so release modes are required for plan9. See port/plan9/NOTES.md.
#
# Config (env): ZIG9_DEV  "host port" for listen1 delivery (default QEMU VM
# "127.0.0.1 1717"; cirno bare metal is "192.168.88.159 17010").
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"           # zig9/
ZIG="$HERE/vendor/zig-host/zig"
LIB="$HERE/vendor/zig/lib"
[ -x "$ZIG" ] || { echo "missing $ZIG — run zig9/fetch.sh first"; exit 1; }

cmd="${1:-}"; src="${2:-}"; opt="${3:--OReleaseSmall}"
{ [ -n "$cmd" ] && [ -n "$src" ]; } || { echo "usage: zig9 build|run SRC [-Oopt]"; exit 2; }

base="$(basename "$src")"; out="/tmp/${base%.zig}.aout"
# -mcpu=x86_64_v2: gives SSE4.1 roundsd/popcnt so @floor/@ceil/@round and friends
# lower to instructions instead of libm/compiler-rt externs (the self-hosted
# backend can't emit named extern refs for plan9 yet). Safe on any amd64 9front.
"$ZIG" build-exe "$src" --zig-lib-dir "$LIB" -target x86_64-plan9 -mcpu=x86_64_v2 "$opt" -femit-bin="$out"
echo "built $out ($(wc -c <"$out") bytes)" >&2

if [ "$cmd" = run ]; then
	read -r dh dp <<<"${ZIG9_DEV:-127.0.0.1 1717}"
	python3 "$HERE/../cc9/host/deliver.py" "$out" "$dh" "$dp"
fi
