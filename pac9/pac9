#!/bin/rc
# pac9 — a package manager for 9front.
#
#   pac9 install <name|git-url>...  clone -> build -> install package(s)
#   pac9 list                       show what's installed (with versions)
#   pac9 uninstall <name>           remove a package (best-effort)
#   pac9 update                     refresh the registry (and pac9 itself)
#   pac9 outdated                   registry version != installed version
#   pac9 upgrade [<name>...]        reinstall those whose version changed
#   pac9 changelog <name>           what changed in the installed version
#
# install takes any number of packages. A registry entry may name
# dependencies (5th column); those are installed first if not already
# present, so `pac9 install pi9` pulls in vts + vtwin automatically.
#
# The heavy lifting is already done by 9front: git9 (git/clone) fetches
# any repo, and the mkfile + </sys/src/cmd/mkone convention gives every
# well-formed package a `mk install` target. pac9 is the thin wrapper:
# a name->url registry, build-step detection, and an install manifest.
#
# A prebuilt package's recipe can be `tarball <url>`: pac9 fetches the
# tarball, records every path it contains, and unpacks it at /. The record
# lets uninstall delete exactly those files (a plain `rm bin/<name>` can't,
# since e.g. python9's tarball installs `python`, not `python9`).
#
# Versions: a registry entry MAY carry a 6th column, the current version, and
# its release URL should embed that version so the URL is immutable (a tag you
# can overwrite is not a version — the same URL would silently serve different
# bytes, and nobody could pin or roll back). pac9 records the installed version
# in the manifest, so `list`/`outdated`/`upgrade` can compare. Entries without a
# version still work and read as '-' (unversioned/grandfathered); they upgrade
# only via an explicit `pac9 install`.
#
# Runtime state:
#   /sys/lib/pac9/registry   curated  name<tab>url<tab>subdir<tab>recipe<tab>deps<tab>version
#   /sys/lib/pac9/installed  manifest  name url srcdir version  (one line per pkg)
#   /sys/lib/pac9/files/<name>  file list unpacked by a tarball package
#   /sys/lib/pac9/changelog/<name>  shipped by the package's tarball
#   $home/src/pac9/<name>/   cached clone (reused on re-install)

reg=/sys/lib/pac9/registry
manifest=/sys/lib/pac9/installed
srcbase=$home/src/pac9

# newline, for splitting awk output into a list without eating spaces
nl='
'

fn usage {
	echo 'usage: pac9 install <name|git-url>...' >[1=2]
	echo '       pac9 list' >[1=2]
	echo '       pac9 uninstall <name>' >[1=2]
	echo '       pac9 update' >[1=2]
	echo '       pac9 outdated' >[1=2]
	echo '       pac9 upgrade [<name>...]' >[1=2]
	echo '       pac9 changelog <name>' >[1=2]
	exit usage
}

# resolve <arg> -> sets $name $url $subdir $recipe $deps $version
# registry hit wins; otherwise <arg> is a git URL and we default the rest.
# NB: rc drops empty fields when splitting, so a trailing empty column just
# shortens the list -> 3 = no deps/version, 4 = deps only, 5 = deps + version.
# An entry that wants a version MUST therefore give deps as '-', not blank.
fn resolve {
	arg=$1
	entry=()
	deps=()
	version=-
	if(test -f $reg){
		oif=$ifs
		ifs=$nl
		entry=`{awk 'BEGIN{FS="\t"} $1==a{print $2; print $3; print $4; print $5; print $6; exit}' 'a='^$arg $reg}
		ifs=$oif
	}
	if(~ $#entry 3 || ~ $#entry 4 || ~ $#entry 5){
		name=$arg
		url=$entry(1)
		subdir=$entry(2)
		recipe=$entry(3)
		# 5th column is a space-separated dep list; re-split it into words
		if(~ $#entry 4 || ~ $#entry 5)
			if(! ~ $entry(4) -)
				deps=`{echo $entry(4)}
		if(~ $#entry 5)
			version=$entry(5)
	}
	if not {
		url=$arg
		name=`{basename $url .git}
		subdir=.
		recipe=-
	}
}

# registry_version <name> -> the registry's version for <name> ('-' if none)
fn registry_version {
	rv=-
	if(test -f $reg)
		rv=`{awk 'BEGIN{FS="\t"} $1==a{print ($6==""?"-":$6); exit}' 'a='^$1 $reg}
	if(~ $#rv 0)
		rv=-
	echo $rv
}

# installed_version <name> -> version recorded at install ('-' if unknown, e.g.
# a manifest written before versions existed)
fn installed_version {
	iv=-
	if(test -f $manifest)
		iv=`{awk '$1==n{print ($4==""?"-":$4); exit}' 'n='^$1 $manifest}
	if(~ $#iv 0)
		iv=-
	echo $iv
}

# installed_p <name> -> true (exit 0) if the package is in the manifest
fn installed_p {
	test -f $manifest && grep -s '^'$1' ' $manifest
}

# install_tarball <url> <name> -> fetch a .tar.gz, record its file list, unpack at /
fn install_tarball {
	turl=$1
	pkg=$2
	tmp=/tmp/pac9-$pkg.tar
	echo 'pac9: fetching '$turl
	if(! hget $turl >$tmp.gz){
		echo 'pac9: fetch failed: '$turl >[1=2]
		rm -f $tmp.gz
		exit fetch
	}
	gunzip <$tmp.gz >$tmp
	# record what's in the archive so uninstall can remove exactly these
	mkdir -p /sys/lib/pac9/files
	tar tf $tmp >/sys/lib/pac9/files/$pkg
	@{ cd / && tar xf $tmp }
	rm -f $tmp.gz $tmp
}

# build in the current directory, per the detection order in the plan.
fn build {
	d=$1
	if(! ~ $recipe -){
		echo 'pac9: recipe: '$recipe
		eval $recipe
	}
	# an explicit install: target, OR a </sys/src/cmd/mk{one,many,lib} include
	# (which provides one) — the standard Plan 9 convention every mkone package uses.
	if not if(test -f mkfile && grep -s 'install:|/mkone|/mkmany|/mklib' mkfile){
		mk install
	}
	if not if(test -f mkfile){
		mk
		echo 'pac9: mkfile has no install target; binary left in '$d >[1=2]
	}
	if not if(test -f build.rc){
		rc build.rc
	}
	if not if(test -f configure || test -f Makefile || test -f makefile){
		# POSIX / autotools build under APE (9front ships ape/sh + ape/make).
		# For a non-default prefix or configure flags, use a registry recipe.
		# External cmds exit '' on success, so accept 0 and '' below.
		echo 'pac9: building with APE (configure/make)'
		if(test -f configure){
			ape/sh configure
			if(! ~ $status 0 ''){ echo 'pac9: ./configure failed' >[1=2]; exit configure }
		}
		ape/make
		if(! ~ $status 0 ''){ echo 'pac9: make failed' >[1=2]; exit make }
		ape/make install
		if(! ~ $status 0 ''){ echo 'pac9: make install failed (built in '$d')' >[1=2]; exit makeinst }
		echo 'pac9: APE build ok'   # trailing success — the block must not end on a guard `if`
	}
	if not {
		echo 'pac9: no mkfile/build.rc/Makefile in '$d'; build it manually' >[1=2]
		exit nobuild
	}
}

fn install_one {
	resolve $1

	# install missing dependencies first. Each runs in its own subshell
	# so the recursion doesn't clobber this frame's resolve() globals.
	for(d in $deps){
		if(installed_p $d){
			echo 'pac9: dependency '$d' already installed'
		}
		if not {
			echo 'pac9: installing dependency '$d
			@{ install_one $d }
		}
	}

	if(~ $url -){
		# recipe-only package (no repo): a prebuilt tarball or any
		# self-contained command. Used for the big cross-ports
		# (python9/node9/zig9/cc9) whose vendored source isn't cloneable.
		if(~ $recipe -){
			echo 'pac9: '$name' has no url and no recipe' >[1=2]
			exit badpkg
		}
		words=`{echo $recipe}
		if(~ $words(1) tarball){
			install_tarball $words(2) $name
		}
		if not {
			echo 'pac9: recipe: '$recipe
			eval $recipe
		}
		dir=-
	}
	if not {
		# fetch (or update) the source, then build it
		dir=$srcbase/$name
		if(test -d $dir/.git){
			echo 'pac9: updating '$name
			@{ cd $dir && git/pull }
		}
		if not {
			echo 'pac9: cloning '$url
			mkdir -p $srcbase
			git/clone $url $dir
		}
		if(! test -d $dir){
			echo 'pac9: fetch failed for '$name >[1=2]
			exit fetch
		}
		@{ cd $dir/$subdir && build $dir/$subdir }
		# build runs in a subshell, so its exit can't abort us — check
		# the status and bail before recording a failed build as installed.
		# success is '' (an external cmd like mk exits(nil)) or '0' (an rc
		# builtin) — accept both, else a clean `mk install` reads as failure.
		if(! ~ $status 0 ''){
			echo 'pac9: build failed for '$name'; not installed (source cached in '$dir')' >[1=2]
			exit build
		}
	}

	# record it (drop any prior line for this name first)
	mkdir -p /sys/lib/pac9
	if(test -f $manifest){
		awk '$1!=n' 'n='^$name $manifest >$manifest.tmp
		mv $manifest.tmp $manifest
	}
	echo $name $url $dir $version >>$manifest
	if(~ $version -)
		echo 'pac9: installed '$name
	if not
		echo 'pac9: installed '$name' '$version
}

fn cmd_install {
	if(~ $#* 0) usage
	# each package in its own subshell: one failure (a bad recipe, a
	# missing mkfile) aborts that package, not the whole batch.
	for(p in $*){
		@{ install_one $p }
	}
}

fn cmd_list {
	if(! test -f $manifest){
		echo 'pac9: nothing installed'
		exit
	}
	# name, version ('-' for pre-versioning installs), source
	awk '{print $1"\t"($4==""?"-":$4)"\t"$2}' $manifest
}

# outdated -> print "<name> <installed> <registry>" for each package whose
# registry version differs from what's installed. Unversioned either side is
# skipped: with no version to compare, "outdated" is unanswerable — saying
# nothing beats guessing and nagging a reinstall of a package that is current.
fn outdated_list {
	if(! test -f $manifest)
		exit
	for(n in `{awk '{print $1}' $manifest}){
		iv=`{installed_version $n}
		rv=`{registry_version $n}
		if(! ~ $iv - && ! ~ $rv - && ! ~ $iv $rv)
			echo $n $iv $rv
	}
}

fn cmd_outdated {
	out=`{outdated_list}
	if(~ $#out 0){
		echo 'pac9: everything is current'
		exit ''
	}
	outdated_list | awk '{print $1"\t"$2"\t->\t"$3}'
}

fn cmd_upgrade {
	if(~ $#* 0){
		# no names: upgrade everything the registry says has moved
		names=`{outdated_list | awk '{print $1}'}
		if(~ $#names 0){
			echo 'pac9: everything is current'
			exit ''
		}
	}
	if not
		names=$*
	for(p in $names){
		iv=`{installed_version $p}
		rv=`{registry_version $p}
		if(~ $iv $rv && ! ~ $rv -){
			echo 'pac9: '$p' is already '$rv
		}
		if not {
			echo 'pac9: upgrading '$p' '$iv' -> '$rv
			@{ install_one $p }
		}
	}
}

fn cmd_changelog {
	if(~ $#* 0) usage
	f=/sys/lib/pac9/changelog/$1
	if(test -f $f){
		cat $f
		exit ''
	}
	echo 'pac9: no changelog shipped for '$1 >[1=2]
	exit nochangelog
}

fn cmd_uninstall {
	if(~ $#* 0) usage
	name=$1
	if(! test -f $manifest){
		echo 'pac9: nothing installed' >[1=2]
		exit
	}
	dir=`{awk '$1==n{print $3; exit}' 'n='^$name $manifest}
	if(~ $#dir 0){
		echo 'pac9: '$name' is not installed' >[1=2]
		exit notinstalled
	}

	# removal, most precise first:
	#  1. a recorded file list (tarball packages) -> delete exactly those
	#  2. `mk uninstall` if the source mkfile offers it
	#  3. fall back to rm /$objtype/bin/<name>
	flist=/sys/lib/pac9/files/$name
	if(test -f $flist){
		echo 'pac9: removing files recorded for '$name
		for(f in `{grep -v '/$' $flist}){
			rm -f /$f
		}
		# drop package dirs that are now empty. Plan 9 has no rmdir; `rm`
		# on a dir removes it only if empty (errors, harmlessly, on shared
		# dirs like /amd64/bin). Deepest-first — sort by path length
		# descending so every child clears before its parent, in one pass.
		for(d in `{grep '/$' $flist | sed 's,/$,,' | awk '{print length($0), $0}' | sort -rn | sed 's/^[0-9]* //'}){
			rm /$d >[2]/dev/null
		}
		rm -f $flist
	}
	if not if(! ~ $dir - && test -f $dir/mkfile && grep -s 'uninstall:' $dir/mkfile){
		@{ cd $dir && mk uninstall }
	}
	if not {
		# ponytail: last resort for a package with no file list and no
		# uninstall target — assumes the binary matches the package name.
		rm -f /$objtype/bin/$name
	}

	if(! ~ $dir -)
		rm -rf $dir
	awk '$1!=n' 'n='^$name $manifest >$manifest.tmp
	mv $manifest.tmp $manifest
	echo 'pac9: removed '$name
}

# refresh the registry, then pac9 itself, from the repo's main branch.
# A new package in the registry is unusable until the box refreshes its
# local copy — this is that refresh. Self-replacing a running rc script
# is safe here: the fn body is fully parsed before it runs, and exit
# ensures rc never reads the (rewritten) script file again.
fn cmd_update {
	rawbase=https://raw.githubusercontent.com/Alino/agent9/main/pac9
	mkdir -p /sys/lib/pac9
	if(! hget $rawbase/registry >/tmp/pac9.reg || ! grep -s tarball /tmp/pac9.reg){
		echo 'pac9: registry fetch failed' >[1=2]
		rm -f /tmp/pac9.reg
		exit fetch
	}
	cp /tmp/pac9.reg $reg
	rm -f /tmp/pac9.reg
	echo 'pac9: registry updated'
	hget $rawbase/pac9 >/tmp/pac9.new
	if(~ $status 0 '' && grep -s 'package manager for 9front' /tmp/pac9.new){
		cp /tmp/pac9.new /rc/bin/pac9
		chmod +x /rc/bin/pac9
		echo 'pac9: pac9 updated'
	}
	if not
		echo 'pac9: self-update skipped (fetch failed)' >[1=2]
	rm -f /tmp/pac9.new
	exit ''
}

if(~ $#* 0) usage
sub=$1
shift
switch($sub){
case install
	cmd_install $*
case list
	cmd_list $*
case uninstall remove
	cmd_uninstall $*
case update
	cmd_update $*
case outdated
	cmd_outdated $*
case upgrade
	cmd_upgrade $*
case changelog
	cmd_changelog $*
case *
	usage
}
