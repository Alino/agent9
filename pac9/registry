# pac9 curated package registry.
# Columns are TAB-separated:  name<TAB>url<TAB>subdir<TAB>recipe<TAB>deps
#   subdir  '.' = repo root
#   recipe  '-' = default detection (mk install if the mkfile has that target)
#   deps    optional 5th column: space-separated package names installed
#           first if not already present (omit or '-' for none)
# Unknown names fall through to being treated as a git URL, so this file
# only needs entries for packages that want a short name or a custom build.
#
netsurf	https://github.com/netsurf-plan9/nsport	.	fetch clone http; mk; mk install

# Prebuilt cross-ports.  url '-' = no repo to clone; the recipe fetches a
# release tarball and unpacks it at / (paths inside are amd64/bin/... and
# sys/lib/...).  These build from vendored upstream that isn't cloneable, so
# we ship built artifacts (as node9/python9 already do via hget|gunzip|tar).
# ponytail: tarball URLs are placeholders — point them at the GitHub Release
# assets once published.
python9	-	.	cd /; hget https://github.com/Alino/agent9/releases/download/py/python9-amd64.tar.gz | gunzip | tar x
node9	-	.	cd /; hget https://github.com/Alino/agent9/releases/download/node/node9-amd64.tar.gz | gunzip | tar x
zig9	-	.	cd /; hget https://github.com/Alino/agent9/releases/download/zig/zig9-amd64.tar.gz | gunzip | tar x
cc9	-	.	cd /; hget https://github.com/Alino/agent9/releases/download/cc9/cc9-amd64.tar.gz | gunzip | tar x
# pi9: prebuilt tarball has amd64/bin/pi9, rc/bin/new-pi9, sys/lib/tls/ca.pem.
# It renders through a vts session, so it depends on vts + vtwin (5th column,
# pulled in automatically).
pi9	-	.	cd /; hget https://github.com/Alino/agent9/releases/download/pi9/pi9-amd64.tar.gz | gunzip | tar x	vts vtwin
mxio	https://github.com/Alino/agent9	src/mxio	-
vts	https://github.com/Alino/agent9	src/vts	-
vtwin	https://github.com/Alino/agent9	src/vtwin	-
xena-panel	https://github.com/Alino/agent9	src/xena-panel	-
launcher	https://github.com/Alino/agent9	src/launcher	-
