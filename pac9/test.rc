#!/bin/rc
# test.rc — self-check for pac9. Run on the 9front box after install.rc.
# No git or network: appends throwaway recipe-only packages to the registry
# and checks install, dependency resolution, the manifest, and uninstall.
# Restores the registry afterward.
reg=/sys/lib/pac9/registry
man=/sys/lib/pac9/installed
tab='	'
tout=/tmp/pac9test.out
dout=/tmp/pac9dep.out

fn fail { echo 'FAIL:' $* >[1=2]; exit fail }

if(! test -x /rc/bin/pac9) fail 'pac9 not installed (run install.rc first)'
mkdir -p /sys/lib/pac9
rm -f $tout $dout

# snapshot the registry, then append a dependency and a package that
# declares it (5th column). Each recipe just drops a marker file.
cp $reg $reg.bak
echo 'pac9dep'^$tab^'-'^$tab^'.'^$tab^'echo dep >'^$dout >>$reg
echo 'pac9test'^$tab^'-'^$tab^'.'^$tab^'echo built >'^$tout^$tab^'pac9dep' >>$reg

pac9 install pac9test
if(! test -f $tout) fail 'recipe did not run'
if(! test -f $dout) fail 'dependency was not installed'
if(! grep -s '^pac9test ' $man) fail 'manifest missing pac9test after install'
if(! grep -s '^pac9dep ' $man) fail 'manifest missing the dependency'

pac9 uninstall pac9test
pac9 uninstall pac9dep
if(grep -s '^pac9test ' $man) fail 'pac9test still in manifest after uninstall'
if(grep -s '^pac9dep ' $man) fail 'pac9dep still in manifest after uninstall'

# file-manifest uninstall (the path a `tarball` package takes): seed a fake
# installed tree + recorded file list, then check uninstall deletes exactly it.
rm -rf /tmp/pac9tf
mkdir -p /tmp/pac9tf
touch /tmp/pac9tf/a /tmp/pac9tf/b
mkdir -p /sys/lib/pac9/files
echo 'tmp/pac9tf/a
tmp/pac9tf/b
tmp/pac9tf/' >/sys/lib/pac9/files/pac9tb
echo 'pac9tb - -' >>$man
pac9 uninstall pac9tb
if(test -f /tmp/pac9tf/a) fail 'file-manifest uninstall left a file behind'
if(test -d /tmp/pac9tf) fail 'file-manifest uninstall left the empty dir'
if(test -f /sys/lib/pac9/files/pac9tb) fail 'file list not removed'
if(grep -s '^pac9tb ' $man) fail 'pac9tb still in manifest'

mv $reg.bak $reg
rm -f $tout $dout
echo PASS
