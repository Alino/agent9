#!/bin/rc
# test.rc — self-check for pac9. Run on the 9front box after install.rc.
# No git or network: appends throwaway recipe-only packages to the registry
# and checks install, dependency resolution, the manifest, and uninstall.
# Restores the registry afterward.
reg=/sys/lib/pac9/registry
man=/sys/lib/pac9/installed
tab='	'
tout=/tmp/pac9test.out
dout=/tmp/pac9dep.out

fn fail { echo 'FAIL:' $* >[1=2]; exit fail }

if(! test -x /rc/bin/pac9) fail 'pac9 not installed (run install.rc first)'
mkdir -p /sys/lib/pac9
rm -f $tout $dout

# snapshot the registry, then append a dependency and a package that
# declares it (5th column). Each recipe just drops a marker file.
cp $reg $reg.bak
echo 'pac9dep'^$tab^'-'^$tab^'.'^$tab^'echo dep >'^$dout >>$reg
echo 'pac9test'^$tab^'-'^$tab^'.'^$tab^'echo built >'^$tout^$tab^'pac9dep' >>$reg

pac9 install pac9test
if(! test -f $tout) fail 'recipe did not run'
if(! test -f $dout) fail 'dependency was not installed'
if(! grep -s '^pac9test ' $man) fail 'manifest missing pac9test after install'
if(! grep -s '^pac9dep ' $man) fail 'manifest missing the dependency'

pac9 uninstall pac9test
pac9 uninstall pac9dep
if(grep -s '^pac9test ' $man) fail 'pac9test still in manifest after uninstall'
if(grep -s '^pac9dep ' $man) fail 'pac9dep still in manifest after uninstall'

# file-manifest uninstall (the path a `tarball` package takes): seed a fake
# installed tree + recorded file list, then check uninstall deletes exactly it.
rm -rf /tmp/pac9tf
mkdir -p /tmp/pac9tf
touch /tmp/pac9tf/a /tmp/pac9tf/b
mkdir -p /sys/lib/pac9/files
echo 'tmp/pac9tf/a
tmp/pac9tf/b
tmp/pac9tf/' >/sys/lib/pac9/files/pac9tb
echo 'pac9tb - -' >>$man
pac9 uninstall pac9tb
if(test -f /tmp/pac9tf/a) fail 'file-manifest uninstall left a file behind'
if(test -d /tmp/pac9tf) fail 'file-manifest uninstall left the empty dir'
if(test -f /sys/lib/pac9/files/pac9tb) fail 'file list not removed'
if(grep -s '^pac9tb ' $man) fail 'pac9tb still in manifest'

# --- versions ---
# The registry's optional 6th column. rc drops empty fields when splitting, so
# the field COUNT is what resolve keys on: 3 = bare, 4 = deps, 5 = deps+version.
# These cases are exactly where that can go wrong, so cover all three shapes.
vout=/tmp/pac9ver.out
rm -f $vout
echo 'pac9v1'^$tab^'-'^$tab^'.'^$tab^'echo v >'^$vout^$tab^'-'^$tab^'0.2.0' >>$reg
echo 'pac9v2'^$tab^'-'^$tab^'.'^$tab^'echo v >'^$vout^$tab^'-'^$tab^'1.0.0' >>$reg

# a versioned install must record its version in the manifest (4th field)
pac9 install pac9v1
if(! test -f $vout) fail 'versioned recipe did not run'
if(! grep -s '^pac9v1 .* 0.2.0$' $man) fail 'manifest did not record the version'
if(! pac9 list | grep -s 'pac9v1	0.2.0') fail 'list does not show the version'

# installed 0.2.0 vs registry 0.2.0 -> current, must NOT be outdated
if(pac9 outdated | grep -s '^pac9v1') fail 'current package reported outdated'

# pin the manifest back a version -> now it must be outdated, and upgrade fixes it
awk '$1!=n' 'n=pac9v1' $man >$man.tmp
mv $man.tmp $man
echo 'pac9v1 - - 0.1.0' >>$man
if(! pac9 outdated | grep -s '^pac9v1') fail 'stale package not reported outdated'
pac9 upgrade pac9v1
if(! grep -s '^pac9v1 .* 0.2.0$' $man) fail 'upgrade did not record the new version'
if(pac9 outdated | grep -s '^pac9v1') fail 'still outdated after upgrade'

# a package the REGISTRY doesn't version is never outdated — nothing to compare
echo 'pac9u1 - - ' >>$man
if(pac9 outdated | grep -s '^pac9u1') fail 'registry-unversioned package reported outdated'

# but an install with NO recorded version IS outdated once the registry names
# one ('?' -> 0.2.0). This is the grandfathered case — every package installed
# before versioning existed. If this reports "current", the whole feature is dead
# on arrival for existing users, which is exactly the bug this pins down.
awk '$1!=n' 'n=pac9v1' $man >$man.tmp
mv $man.tmp $man
echo 'pac9v1 - -' >>$man
if(! pac9 outdated | grep -s '^pac9v1.*\?.*0.2.0') fail 'unversioned install not offered the versioned release'
pac9 upgrade pac9v1
if(! grep -s '^pac9v1 .* 0.2.0$' $man) fail 'upgrade from unversioned did not record the version'

# changelog: present -> printed; absent -> non-zero exit
mkdir -p /sys/lib/pac9/changelog
echo 'hello changelog' >/sys/lib/pac9/changelog/pac9v1
if(! pac9 changelog pac9v1 | grep -s 'hello changelog') fail 'changelog not printed'
if(pac9 changelog pac9nope >[2]/dev/null) fail 'missing changelog should fail'
rm -f /sys/lib/pac9/changelog/pac9v1

pac9 uninstall pac9v1
awk '$1!=n' 'n=pac9u1' $man >$man.tmp
mv $man.tmp $man

mv $reg.bak $reg
rm -f $tout $dout $vout
echo PASS
