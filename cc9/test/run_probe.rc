#!/bin/rc
# Build + run exec_probe on cirno, logging everything to /tmp/probe.log.
cd /tmp
rm -f exec_probe.6 exec_probe probe.log
6c -FTVw exec_probe.c >/tmp/probe.log >[2=1]
echo cc=$status >>/tmp/probe.log
6l -o exec_probe exec_probe.6 >>/tmp/probe.log >[2=1]
echo ld=$status >>/tmp/probe.log
/tmp/exec_probe >>/tmp/probe.log >[2=1]
echo run=$status >>/tmp/probe.log
echo PROBE_SCRIPT_DONE >>/tmp/probe.log
