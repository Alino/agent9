#!/bin/rc
# cc-on9 — on-box (9front) driver for the cc9-built clang.
#
# WHY THIS EXISTS: the cc9-built clang crashes when the KERNEL passes it >= 9
# argv entries (8 args after argv[0] is fine, 9 crashes — for ANY 9th arg; it is
# NOT cc9's argv, which handles 16+ args correctly, but clang's own early argv
# processing — InitLLVM/ExpandResponseFiles — hitting a cc9-runtime edge). The fix
# until that root cause is found: pass the args via a RESPONSE FILE, so the kernel
# sees only `clang @file` (2 argv) while clang expands the many real args itself.
# Proven: lambda + -std=c++17 + -O2 + 14 internal args all compile correctly this way.
#
# Usage:  cc-on9 -cc1 -triple x86_64-unknown-none -std=c++17 -emit-obj foo.cpp -o foo.o
# (i.e. exactly the args you'd pass clang; they are forwarded via the response file.)
#
# ponytail: args are space-joined into the response file; this is fine for the libc++
# conformance suite (no args contain spaces). If an arg ever needs a space, quote it in
# the response file instead — add that only when a real test needs it.

clang = /bin/clang
if (! test -x $clang) clang = /usr/glenda/clang

rsp = /tmp/cc9rsp.$pid
echo $* > $rsp
$clang @$rsp
status = $status
rm -f $rsp
exit $status
