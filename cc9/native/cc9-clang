#!/bin/bash
# cc9-clang — C compile wrapper for the cc9 cross-toolchain (CMAKE_C_COMPILER).
# Transparent: forwards every arg to host clang, injecting only the cc9
# freestanding target (so CMake/LLVM keeps full control of its own flags).
set -euo pipefail
CC9="$(cd "$(dirname "$0")/.." && pwd)"
LLVM="${CC9_LLVM:-/opt/homebrew/opt/llvm/bin}"
exec "$LLVM/clang" --target=x86_64-unknown-none -nostdlib -fno-pic -femulated-tls \
  -isystem "$CC9/runtime/include" "$@"
