#!/bin/bash
# cc9 — compile a C/C++ source to a runnable 9front amd64 a.out (and run it).
#   cc9 build SRC      compile + link + convert -> /tmp/<src>.aout
#   cc9 run   SRC      build, then deliver to cirno and run it
#
# Config (env): CC9_LLVM, CC9_LLD, CC9_LIBCXX (freestanding libc++ headers),
# CC9_DEV ("host port" for listen1, default "127.0.0.1 1717").
# Prereq: cc9/lib/libcc9cxx.a (build with cc9/host/build-runtime.sh) and the
# freestanding libc++ header tree at CC9_LIBCXX.
set -euo pipefail
CC9="$(cd "$(dirname "$0")/.." && pwd)"
LLVM="${CC9_LLVM:-/opt/homebrew/opt/llvm/bin}"
LLD="${CC9_LLD:-$(brew --prefix lld)/bin/ld.lld}"
LIBCXX="${CC9_LIBCXX:-/tmp/libcxx-build/include/c++/v1}"
INC="$CC9/runtime/include"; LIB="$CC9/lib/libcc9cxx.a"; LIBM="$CC9/lib/libcc9m.a"; LDS="$CC9/test/plan9.ld"

cmd="${1:-}"; src="${2:-}"
{ [ -n "$cmd" ] && [ -n "$src" ]; } || { echo "usage: cc9 build|run SRC"; exit 2; }
[ -f "$LIB" ] || { echo "missing $LIB — run cc9/host/build-runtime.sh first"; exit 1; }

base="$(basename "$src")"; obj="/tmp/$base.o"; elf="/tmp/$base.elf"; out="/tmp/$base.aout"
case "$src" in
  *.cpp|*.cc|*.cxx|*.C) CC="$LLVM/clang++"; STD=(-std=c++23 -nostdinc++ -isystem "$LIBCXX") ;;
  *) CC="$LLVM/clang"; STD=() ;;
esac

# NB: no -ffreestanding for user code — it would mangle `main` (the crt0 entry
# expects the unmangled symbol). -nostdlib + the freestanding libc++ headers
# still keep it self-contained.
"$CC" --target=x86_64-unknown-none -nostdlib -DNDEBUG \
  "${STD[@]}" -isystem "$INC" -fno-exceptions -fno-rtti -fno-threadsafe-statics \
  -c "$src" -o "$obj"
# --start-group: the runtime and libm are mutually dependent (libm needs
# memcpy/fenv from the runtime; the runtime's math comes from libm).
"$LLD" -o "$elf" "$obj" --start-group "$LIB" "$LIBM" --end-group -T "$LDS" -static -nostdlib
python3 "$CC9/host/elf2aout.py" "$elf" "$out" >&2   # diagnostics to stderr

if [ "$cmd" = run ]; then
  read -r dh dp <<<"${CC9_DEV:-127.0.0.1 1717}"
  python3 "$CC9/host/deliver.py" "$out" "$dh" "$dp"
fi
