#!/bin/rc
# Auto-deploy script — fetches and runs everything
cp /usr/glenda/bin/rc/riostart /tmp/riostart.bak
hget http://10.0.2.2:8765/riostart > /usr/glenda/bin/rc/riostart
hget http://10.0.2.2:8765/mxio/rio.c > /sys/src/cmd/mxio/rio.c
hget http://10.0.2.2:8765/mxio/wind.c > /sys/src/cmd/mxio/wind.c
hget http://10.0.2.2:8765/mxio/dat.h > /sys/src/cmd/mxio/dat.h
hget http://10.0.2.2:8765/xena-panel/xena-panel.c > /sys/src/cmd/xena-panel/xena-panel.c
cd /sys/src/cmd/mxio && mk install >>/tmp/build.log >[2=1]
cd /sys/src/cmd/xena-panel && mk install >>/tmp/build.log >[2=1]
echo DEPLOY_DONE
