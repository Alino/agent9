#!/bin/rc
# new-pi9 — spawn a new vts session, auto-run pi9 inside it, open vtwin.
#
# Invoked via `window new-pi9` from the start menu. Creates a fresh
# vts session, queues `pi9` for the session's rc to execute, then
# attaches a vtwin window. The user sees pi9 come up immediately.
#
# Pi9 reads its config from $home/lib/pi9/config (per Phase 8). On
# first launch with no config file, pi9 writes a template and exits
# with a helpful pointer; the user edits config, re-runs.
#
# Why queue `pi9` via /n/vts/<s>/cons instead of `vtwin -e pi9`:
# vtwin doesn't have an -e flag (yet); cons feeding is the path
# vts/vtwin support today, and it keeps the rc shell alive after
# pi9 exits so the user can re-run with /quit or tweak env.

mount /srv/vts /n/vts >[2]/dev/null

sess=pi9-$pid
echo new $sess > /n/vts/ctl
if(! test -d /n/vts/$sess){
	echo 'new-pi9: failed to create vts session' >[1=2]
	sleep 3
	exit no-vts
}

# Give the new vts session's rc time to actually start and block
# on read(cons). Without this delay, on a fast machine our write
# to cons can race ahead of rc spinning up — the write is lost
# and rc presents a bare prompt instead of running pi9.
# 500ms is comfortable on the slowest VMs we've tested.
sleep 1

# Queue `pi9` as the first line for the rc inside the new session.
# Since we just created the session, rc has just started and is
# blocked on read from cons. Our write becomes the first thing it
# sees.
if(test -x /bin/pi9){
	echo pi9 > /n/vts/$sess/cons
}
if(! test -x /bin/pi9 && test -x /tmp/pi9){
	echo /tmp/pi9 > /n/vts/$sess/cons
}
if(! test -x /bin/pi9 && ! test -x /tmp/pi9){
	echo 'echo new-pi9: no pi9 binary in /bin or /tmp' > /n/vts/$sess/cons
}

# Spawn vtwin attached to the session. Foreground; on close vtwin
# exits and (via rio's `window` wrapper) the subtree goes away.
#
# Font selection precedence:
#   1. $pi9font env var (rarely works because new-pi9 may be invoked
#      via `window` which goes through rio — and rio doesn't propagate
#      caller's env to spawned windows)
#   2. $font env var (same caveat)
#   3. $home/lib/pi9/font (per-user persistent config file) — this is
#      the RELIABLE path because we read it directly, no env needed
#   4. vtwin's libdraw default
#
# To set a font permanently, drop a one-line file at
# $home/lib/pi9/font containing the libdraw font path, e.g.:
#   echo /lib/font/bit/dejavusans/unicode.14.font > $home/lib/pi9/font
#
# Try these for visible difference vs default vga.font:
#   /lib/font/bit/dejavusans/unicode.18.font  much larger, smooth
#   /lib/font/bit/dejavusans/unicode.14.font  larger, smooth
#   /lib/font/bit/dejavusans/unicode.12.font  slightly larger
fontarg=()

# Priority 1: $home/lib/pi9/font config file (highest — user has
# explicitly opted in by creating this file).
if(test -r $home/lib/pi9/font){
	f=`{cat $home/lib/pi9/font | sed 's/[ 	]*$//'}
	if(~ $#f 1 && ! ~ $f '')
		fontarg=(-f $f)
}

# Priority 2: hardcoded Terminus 16 if installed. Without this, $font
# typically resolves to vga.font (the rio-wide default) and we'd
# render in the boring small font even though Terminus is right there.
# Putting this BEFORE the env-var fallback ensures sensible default.
if(~ $#fontarg 0 && test -r /lib/font/bit/terminus/unicode.16.font)
	fontarg=(-f /lib/font/bit/terminus/unicode.16.font)

# Priority 3: $pi9font env var (rarely works because of rio's
# namespace handling — see wiki/concepts/pi9-phase11.md).
if(~ $#fontarg 0 && ~ $#pi9font 1)
	fontarg=(-f $pi9font)

# Priority 4: $font env var (same caveat).
if(~ $#fontarg 0 && ~ $#font 1)
	fontarg=(-f $font)

# Priority 5: vtwin's libdraw default (typically vga.font). No -f
# passed; vtwin handles it internally.

# Log what font we're actually using so the user can confirm.
# Goes to /tmp/new-pi9.log so it's easy to inspect.
{
	echo 'new-pi9 launched at:' `{date}
	echo '  session:' $sess
	echo '  pi9font env:' `{if(~ $#pi9font 1) echo $pi9font; if(~ $#pi9font 0) echo '(unset)'}
	echo '  font env:' `{if(~ $#font 1) echo $font; if(~ $#font 0) echo '(unset)'}
	echo '  config file ($home/lib/pi9/font):' `{if(test -r $home/lib/pi9/font) cat $home/lib/pi9/font; if(! test -r $home/lib/pi9/font) echo '(none)'}
	echo '  vtwin args:' $fontarg $sess
} >> /tmp/new-pi9.log

# Debug flags: drop a file at $home/lib/pi9/debug to enable input
# logging. File can contain `key`, `mouse`, or both — vtwin then
# logs to /tmp/vt-key.log and /tmp/vt-mouse.log respectively.
# Useful for discovering what Cmd+C/Option+V/etc actually produce
# on your specific VNC client.
debugarg=()
if(test -r $home/lib/pi9/debug){
	cfg=`{cat $home/lib/pi9/debug}
	for(t in $cfg){
		if(~ $t key) debugarg=($debugarg -K)
		if(~ $t mouse) debugarg=($debugarg -M)
	}
}

exec vtwin $fontarg $debugarg $sess
