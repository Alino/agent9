# pi9 mkfile — installs a pre-built pi9 binary into /$cputype/bin/pi9
# and the new-pi9 wrapper into /rc/bin/.
#
# pi9 itself is a Go program. plan9 doesn't have a Go toolchain, so
# we cross-compile on the host (Mac/Linux) and ship the binary into
# the VM. This mkfile only handles the install step — it expects
# pi9.plan9.$cputype to already exist in this directory.
#
# Typical flow:
#   # on Mac:
#   cd src/pi9 && GOOS=plan9 GOARCH=amd64 go build -o pi9.plan9.amd64 .
#   # copy pi9.plan9.amd64 + new-pi9 + mkfile to plan9 (hget, scp, etc.)
#   # on plan9:
#   mk install

</$objtype/mkfile

TARG=pi9
BIN=/$objtype/bin

# Pre-built binary name follows GOOS/GOARCH conventions.
PI9BIN=pi9.plan9.$objtype

all:V: $PI9BIN

$PI9BIN:
	@echo 'pi9: binary missing. cross-compile on the host:'
	@echo '  GOOS=plan9 GOARCH='$objtype' go build -o '$PI9BIN' .'
	@exit pi9-needs-cross-build

install:V: $PI9BIN ../launcher/new-pi9
	cp $PI9BIN $BIN/$TARG
	chmod +x $BIN/$TARG
	cp ../launcher/new-pi9 /rc/bin/new-pi9
	chmod +x /rc/bin/new-pi9
	@echo 'installed:'
	@ls -l $BIN/$TARG /rc/bin/new-pi9

uninstall:V:
	rm -f $BIN/$TARG /rc/bin/new-pi9
	@echo 'uninstalled pi9 + new-pi9'

clean:V:
	rm -f $PI9BIN

nuke:V: clean
	# Nuke everything pi9-related under $home/lib/pi9. Confirm:
	@echo 'this will rm -rf $home/lib/pi9 — press ctrl-c within 5s to abort'
	sleep 5
	rm -rf $home/lib/pi9
