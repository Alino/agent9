#!/bin/rc
# Run vts-attach, send some content, verify VT100 output has the text.
/amd64/bin/vts-attach > /tmp/attach.out >[2] /tmp/attach.err &
APID=$apid
sleep 1
mount -c /srv/vts /n/vts >[2]/dev/null
awk 'BEGIN{printf "VTS_WORKS"}' > /n/vts/1/cons
sleep 2
echo kill > /proc/$APID/note >[2]/dev/null
sleep 1
echo === stderr ===
cat /tmp/attach.err | head -10
echo === look for VTS_WORKS chars in output ===
# Look for the rune bytes V (56), T (54), S (53)
xd /tmp/attach.out > /tmp/attach.xd
# V is 0x56, T is 0x54, S is 0x53, _ is 0x5f, W is 0x57
# Plus rune u32 bytes: V_rune = 56 00 00 00
grep -c '56 00' /tmp/attach.xd
grep -c '54 00' /tmp/attach.xd
echo --- xd of last 50 lines ---
tail -50 /tmp/attach.xd
