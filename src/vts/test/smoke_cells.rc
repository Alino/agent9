#!/bin/rc
# Phase 2.5 cells-protocol smoke test.
# Run AFTER vts is started (or this script starts it).

fn fail { echo 'FAIL: '^$*; exit 1 }
fn ok   { echo '  ok' }

# Kill any existing instance
if(test -e /srv/vts) rm /srv/vts
unmount /n/vts >[2]/dev/null

# Start fresh
/amd64/bin/vts || fail 'start vts'
sleep 1
test -e /srv/vts || fail '/srv/vts missing after start'

mount -c /srv/vts /n/vts || fail mount

echo '=== 1. first read of cells gives full screen ==='
# 24*80=1920 cells × 12 bytes each + 22 header = 23062 bytes
dd -if /n/vts/1/cells -of /tmp/cells.bin -bs 65536 -count 1 >[2]/dev/null
ls -l /tmp/cells.bin
sz=`{wc -c /tmp/cells.bin | awk '{print $1}'}
echo 'got size: '^$sz
if(! ~ $sz 23062) fail 'expected size 23062, got '^$sz
ok

echo '=== 2. magic and header sane ==='
# First 4 bytes are magic 0x76746331 = '31 63 74 76' (little-endian).
xd -b /tmp/cells.bin > /tmp/cells.xd
head1=`{sed 1q /tmp/cells.xd}
echo 'head: '$"head1
~ $"head1 *'31 63 74 76'* || fail 'magic bytes wrong'
ok

echo '=== 3. second read after no changes returns header-only ==='
dd -if /n/vts/1/cells -of /tmp/cells2.bin -bs 65536 -count 1 >[2]/dev/null
sz2=`{wc -c /tmp/cells2.bin | awk '{print $1}'}
echo 'got size: '^$sz2
if(! ~ $sz2 22) fail 'expected size 22 (header only), got '^$sz2
ok

echo '=== 4. after writing to cons, cells reports the changed cells ==='
awk 'BEGIN{printf "\033[1;1HHI"}' > /n/vts/1/cons
dd -if /n/vts/1/cells -of /tmp/cells3.bin -bs 65536 -count 1 >[2]/dev/null
sz3=`{wc -c /tmp/cells3.bin | awk '{print $1}'}
echo 'got size: '^$sz3
# 22 (header) + 2 cells (H + I) × 12 = 46
if(! ~ $sz3 46) fail 'expected 46 bytes (header + 2 cells), got '^$sz3
ok

echo '=== 5. each cell payload encodes row/col/rune correctly ==='
# Cell 1: rune=H(0x48); Cell 2: rune=I(0x49)
xd -b /tmp/cells3.bin > /tmp/cells3.xd
all=`{cat /tmp/cells3.xd}
~ $"all *'48 00 00 00'* || fail 'H rune not found in stream'
~ $"all *'49 00 00 00'* || fail 'I rune not found in stream'
ok

echo '=== 6. cursor position in header is (0,2) after writing HI ==='
# Bytes 14..17 of the header are cur_row(u16), cur_col(u16) little-endian.
# After writing "HI" at (0,0) -> cursor at (0,2). Expect bytes:
#   14: 00  cur_row low
#   15: 00  cur_row high
#   16: 02  cur_col low
#   17: 00  cur_col high
# This sequence straddles the 16-byte boundary of xd -b output, so we
# look in the full dump (not just the first line).
all3=`{cat /tmp/cells3.xd}
~ $"all3 *'00 50 00 02 00 00 00'* || fail 'expected cur=0,2 in header (full): '$"all3
ok

echo
echo '=== ALL PASS ==='
