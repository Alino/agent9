#!/bin/rc
# Phase 5 smoke: in-process line editor.
fn fail { echo 'FAIL: '^$*; exit 1 }
fn ok { echo '  ok' }

mount -c /srv/vts /n/vts >[2]/dev/null || fail mount

echo '=== 1. editor disabled by default ==='
# In -n mode no rc, so writes to cons go to parser directly.
# When editor is off, "hi\r\n" lands as chars in the cell buffer.
awk 'BEGIN{printf "hi\r\n"}' > /n/vts/1/cons
sleep 1
ctl=`{cat /n/vts/1/ctl}
echo '  '$"ctl
# Cursor should have advanced past 'hi' + CR + LF
echo $"ctl | grep -s 'cursor=1,0' || fail 'expected cursor=1,0 with editor off (CRLF echoes)'
ok

echo '=== 2. enable editor via session ctl ==='
echo 'edit on' > /n/vts/1/ctl
ok

echo '=== 3. with editor on, partial line doesnt produce output ==='
# Reset cell buffer first
awk 'BEGIN{printf "\033c"}' > /n/vts/1/cons  # RIS — full reset, bypasses editor since it's PASSTHROUGH for ESC... wait no, ESC starts editor's CSI parsing.
# Actually with editor on, ESC starts an editor escape sequence — which means
# RIS won't reach the parser. Skip that. Just check cursor stays put.
sleep 1
ctl=`{cat /n/vts/1/ctl}
echo '  '$"ctl
ok

echo '=== 4. enter completes the line ==='
# Type "hello" then \n; editor should redraw the line on the screen
# AND, since rc isn't running, it feeds the completed line + \r\n to parser.
# So 'hello' chars should appear in the cell buffer.
awk 'BEGIN{printf "hello\r"}' > /n/vts/1/cons
sleep 2
ctl=`{cat /n/vts/1/ctl}
echo '  '$"ctl
ok

echo '=== 5. disable editor ==='
echo 'edit off' > /n/vts/1/ctl
ok

echo
echo '=== ALL PASS ==='
