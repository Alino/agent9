#!/bin/rc
# Test vts-attach -r (read-only) still works.
/amd64/bin/vts-attach -r > /tmp/attach.out >[2] /tmp/attach.err &
APID=$apid
sleep 1
mount -c /srv/vts /n/vts >[2]/dev/null
awk 'BEGIN{printf "READONLY_OK"}' > /n/vts/1/cons
sleep 2
echo kill > /proc/$APID/note >[2]/dev/null
sleep 1
echo === sizes ===
ls -l /tmp/attach.out /tmp/attach.err
echo === found R ===
xd -c /tmp/attach.out | grep -c R
