#!/bin/rc
# Phase 6 smoke: multi-session.
fn fail { echo 'FAIL: '^$*; exit 1 }
fn ok { echo '  ok' }

mount -c /srv/vts /n/vts >[2]/dev/null || fail mount

echo '=== 1. baseline: session 1 exists ==='
ls /n/vts | grep -s 1 || fail 'session 1 missing'
ok

echo '=== 2. create session "work" via /ctl ==='
echo 'new work' > /n/vts/ctl
sleep 1
ls /n/vts | sort > /tmp/ls
echo '  ls /n/vts:'
cat /tmp/ls
grep -s work /tmp/ls || fail 'work session not created'
ok

echo '=== 3. work session has cons/cells/ctl ==='
ls /n/vts/work | sort > /tmp/ls2
cat /tmp/ls2
grep -s cells /tmp/ls2 || fail 'cells missing in work'
grep -s cons /tmp/ls2 || fail 'cons missing in work'
ok

echo '=== 4. work session independent cell buffer ==='
# Write to session 1 cons
awk 'BEGIN{printf "S1_DATA"}' > /n/vts/1/cons
# Write to work cons
awk 'BEGIN{printf "WORK_DATA"}' > /n/vts/work/cons
sleep 1
ctl1=`{cat /n/vts/1/ctl}
ctlw=`{cat /n/vts/work/ctl}
echo '  ctl1: '$"ctl1
echo '  ctlw: '$"ctlw
ok

echo '=== 5. /ctl reports both sessions ==='
cat /n/vts/ctl > /tmp/status
echo '  status:'
cat /tmp/status
grep -s 'sessions=2' /tmp/status || fail 'expected sessions=2 in ctl'
ok

echo '=== 6. kill session work ==='
echo 'kill work' > /n/vts/ctl
sleep 1
ls /n/vts > /tmp/ls3
echo '  after kill:'
cat /tmp/ls3
grep -s work /tmp/ls3 && fail 'work still present after kill'
ok

echo
echo '=== ALL PASS ==='
