#!/bin/rc
# launch-vtwin.rc — start vtwin via mxio's wsys interface.

RIOSRV=/srv/rio.glenda.449
if(! test -e $RIOSRV) {
	echo no rio service: $RIOSRV >[1=2]
	exit notfound
}

# bind mount the rio service. -b alone doesn't take ownership; we need
# to bind it onto something accessible. The auth issue comes from a
# different namespace user being on the wctl. Try without auth check:
echo trying mount...
mount -bc $RIOSRV /mnt/wsys
echo mount_status: $status

echo writing wctl new...
echo 'new -r 80 80 760 540 /amd64/bin/vtwin' > /mnt/wsys/wctl
echo write_status: $status
