#!/bin/bash
# rust9 — compile a Rust source to a runnable 9front amd64 a.out (and run it).
#   rust9 build SRC.rs   -> /tmp/<src>.aout
#   rust9 run   SRC.rs   -> build, deliver to the 9front VM, run
#
# Reuses the cc9 substrate wholesale: cc9's crt0/_start, syscall thunks, malloc,
# libc (libcc9cxx.a), openlibm (libcc9m.a), linker script, elf2aout, deliver.
# The Rust side is just: rustc -> a freestanding staticlib exposing `main`.
# rustc's x86_64-unknown-none emits the same freestanding SysV objects cc9's
# clang pipeline already consumes, so no custom target/linker is needed yet.
#
# Config (env): RUST9_TARGET (default x86_64-unknown-none), CC9 (default ../cc9),
#   CC9_LLD, CC9_DEV ("host port" for listen1, default "127.0.0.1 1717").
# Prereq: rustup target add x86_64-unknown-none; cc9/lib/libcc9cxx.a built.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
RUST9="$(cd "$HERE/.." && pwd)"
CC9="${CC9:-$(cd "$RUST9/../cc9" && pwd)}"
TARGET="${RUST9_TARGET:-x86_64-unknown-none}"
LLD="${CC9_LLD:-$(brew --prefix lld)/bin/ld.lld}"
LIB="$CC9/lib/libcc9cxx.a"; LIBM="$CC9/lib/libcc9m.a"; LDS="$CC9/test/plan9.ld"

cmd="${1:-}"; src="${2:-}"
{ [ -n "$cmd" ] && [ -n "$src" ]; } || { echo "usage: rust9 build|run SRC.rs"; exit 2; }
[ -f "$LIB" ] || { echo "missing $LIB — build the cc9 runtime first (cc9/host/build-runtime.sh)"; exit 1; }

base="$(basename "$src" .rs)"; a="/tmp/$base.rs.a"; elf="/tmp/$base.rs.elf"; out="/tmp/$base.rs.aout"

# Freestanding staticlib: bundles core (+alloc if used) and compiler-builtins,
# exposes `main` for cc9's crt0. panic=abort is the target default (no unwinder).
rustc --target "$TARGET" --crate-type staticlib -O -C panic=abort -o "$a" "$src"

# --start-group: the Rust lib and the cc9 runtime are mutually dependent
# (Rust refs malloc/memcpy/n9_*; crt0 refs `main`).
"$LLD" -o "$elf" --start-group "$a" "$LIB" "$LIBM" --end-group -T "$LDS" -static -nostdlib
python3 "$CC9/host/elf2aout.py" "$elf" "$out" >&2   # diagnostics to stderr

if [ "$cmd" = run ]; then
  read -r dh dp <<<"${CC9_DEV:-127.0.0.1 1717}"
  python3 "$CC9/host/deliver.py" "$out" "$dh" "$dp"
fi
