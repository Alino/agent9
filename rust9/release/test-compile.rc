#!/bin/rc
cd /tmp
rm -f hello hello.rs
echo 'fn main() {' > hello.rs
echo '    let v: Vec<u64> = (1..=100).collect();' >> hello.rs
echo '    let sq: Vec<u64> = v.iter().map(|x| x * x).take(4).collect();' >> hello.rs
echo '    println!("rust9-pac9 sum={} sq={:?}", v.iter().sum::<u64>(), sq);' >> hello.rs
echo '}' >> hello.rs
rustc hello.rs -o hello
echo RUSTC-STATUS $status
./hello
echo RUN-STATUS $status
echo DONE-COMPILE
