#!/bin/rc
# rust9 pac9 install test — stash any manual deploy, point the registry at the
# Mac-served tarball, install, prove the toolchain runs.
if(test -d /usr/glenda/rust) mv /usr/glenda/rust /usr/glenda/rust.premanaged
grep -v '^rust9' /sys/lib/pac9/registry > /tmp/reg.new
echo 'rust9	-	.	tarball http://192.168.88.10:8901/rust9-amd64.tar.gz' >> /tmp/reg.new
cp /tmp/reg.new /sys/lib/pac9/registry
pac9 install rust9
echo INSTALL-STATUS $status
ls /usr/glenda/rust/bin
ls -l /rc/bin/rustc
grep rust9 /sys/lib/pac9/installed
echo DONE-INSTALL
