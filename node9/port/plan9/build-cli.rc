#!/bin/rc
# node9 Phase 1b — full CLI build: engine + quickjs-libc + n9_cli -> ./qjs
cd /usr/glenda/node9
rm -rf work
mkdir work
cd work
hget http://10.0.2.2:8833/qjs-patched.tar.gz >p.tar.gz
gunzip <p.tar.gz >p.tar
tar xf p.tar
hget http://10.0.2.2:8833/n9_cli.c >n9_cli.c
hget http://10.0.2.2:8833/n9_native.c >n9_native.c
hget http://10.0.2.2:8833/n9_sec.c >n9_sec.c
hget http://10.0.2.2:8833/node9_native.h >node9_native.h
rm -f /tmp/cli.log
FLAGS=(-c -I. -DPLAN9 -D__DJGPP -DNO_TM_GMTOFF '-DJS_NAN_BOXING=0' '-D_POSIX_SOURCE' '-D_BSD_EXTENSION' '-D__STDC_NO_ATOMICS__=1')
for(f in quickjs libregexp libunicode dtoa quickjs-libc n9_native n9_cli){
	echo '=== '^$f^' ===' >>/tmp/cli.log
	pcc $FLAGS $f.c >>/tmp/cli.log >[2=1]
}
echo '=== n9_sec (plan9 libsec/libz TU) ===' >>/tmp/cli.log
pcc -c -I. n9_sec.c >>/tmp/cli.log >[2=1]
echo '=== link ===' >>/tmp/cli.log
pcc -o qjs n9_cli.6 n9_native.6 n9_sec.6 quickjs.6 libregexp.6 libunicode.6 dtoa.6 quickjs-libc.6 -lsec -lz >>/tmp/cli.log >[2=1]
echo 'link_status='^$status >>/tmp/cli.log
echo ALL_DONE >>/tmp/cli.log
