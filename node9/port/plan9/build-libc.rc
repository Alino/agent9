#!/bin/rc
# node9 Phase 1 — isolated triage compile of quickjs-libc.c (POSIX-heavy).
cd /usr/glenda/node9
rm -rf libc-test
mkdir libc-test
cd libc-test
hget http://10.0.2.2:8833/qjs-patched.tar.gz >p.tar.gz
gunzip <p.tar.gz >p.tar
tar xf p.tar
rm -f /tmp/libc.log
pcc -c -I. -DPLAN9 -D__DJGPP -DNO_TM_GMTOFF '-DJS_NAN_BOXING=0' '-D_POSIX_SOURCE' '-D_BSD_EXTENSION' '-D__STDC_NO_ATOMICS__=1' quickjs-libc.c >/tmp/libc.log >[2=1]
echo EXIT=$status >>/tmp/libc.log
echo DONE_LIBC >>/tmp/libc.log
