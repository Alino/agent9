#!/bin/rc
# node9 Phase 1 — VM-side: fetch pre-patched tree, compile quickjs.c only.
cd /usr/glenda/node9
rm -rf work
mkdir work
cd work
hget http://10.0.2.2:8833/qjs-patched.tar.gz >p.tar.gz
gunzip <p.tar.gz >p.tar
tar xf p.tar
echo '== COMPILE quickjs.c =='
pcc -c -I. -DPLAN9 -D__DJGPP -DNO_TM_GMTOFF '-D_POSIX_SOURCE' '-D__STDC_NO_ATOMICS__=1' quickjs.c >/tmp/qjs.log >[2=1]
echo 'compile_status='^$status
ls -l quickjs.o >[2=1]
wc -l /tmp/qjs.log
echo '== first 45 log lines =='
sed 45q /tmp/qjs.log
echo '== DONE_COMPILE =='
