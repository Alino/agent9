--- a/Libraries/LibWeb/Platform/FontPlugin.cpp
+++ b/Libraries/LibWeb/Platform/FontPlugin.cpp
@@ -101,6 +101,24 @@ void FontPlugin::update_generic_fonts()
     Vector<FlyString> sans_serif_fallbacks { "Arial"_fly_string, "Helvetica"_fly_string, "Verdana"_fly_string, "Trebuchet MS"_fly_string, "Gill Sans"_fly_string, "Noto Sans"_fly_string, "Avantgarde"_fly_string, "Optima"_fly_string, "Arial Narrow"_fly_string, "Liberation Sans"_fly_string, "Roboto"_fly_string };
     Vector<FlyString> serif_fallbacks { "Times"_fly_string, "Times New Roman"_fly_string, "Didot"_fly_string, "Georgia"_fly_string, "Palatino"_fly_string, "Bookman"_fly_string, "New Century Schoolbook"_fly_string, "American Typewriter"_fly_string, "Liberation Serif"_fly_string, "Roman"_fly_string, "Noto Serif"_fly_string };
 
+#if defined(AK_OS_PLAN9)
+    // Plan 9 has no fontconfig/system fonts, so the CSS generics must resolve to
+    // BUNDLED fonts. Prefer DejaVu (a normal-looking family with broad
+    // Latin/Cyrillic/Greek + symbol coverage) over Ladybird's hand-drawn
+    // SerenitySans house font — SerenitySans reads as "comic sans" and has sparse
+    // Unicode coverage, so on Plan 9 it was making every page look wrong with
+    // missing glyphs. DejaVu {Sans,Serif,Sans Mono} ship in Base/res/fonts (from
+    // ladybird9/port/assets/fonts). Prepend so they win the fallback scoring;
+    // keep SerenitySans as the very last resort so default_font() is never null
+    // (a null default crashes StyleComputer's ctor via default_font(16)->...).
+    // Per-glyph coverage still cascades through the whole set (NotoEmoji, etc.).
+    sans_serif_fallbacks.prepend("DejaVu Sans"_fly_string);
+    serif_fallbacks.prepend("DejaVu Serif"_fly_string);
+    monospace_fallbacks.prepend("DejaVu Sans Mono"_fly_string);
+    sans_serif_fallbacks.append("SerenitySans"_fly_string);
+    serif_fallbacks.append("SerenitySans"_fly_string);
+#endif
+
     auto fallback_set = [&](GenericFont font) -> Vector<FlyString>& {
         return m_generic_font_fallbacks[to_underlying(font)];
     };
