diff --git a/Libraries/LibCore/Socket.cpp b/Libraries/LibCore/Socket.cpp
index 7aecfb1597..0a777bbed8 100644
--- a/Libraries/LibCore/Socket.cpp
+++ b/Libraries/LibCore/Socket.cpp
@@ -508,7 +508,7 @@ ErrorOr<pid_t> LocalSocket::peer_pid() const
 #elif defined(AK_OS_SOLARIS)
     ucred_t* creds = NULL;
     socklen_t creds_size = sizeof(creds);
-#elif defined(AK_OS_GNU_HURD)
+#elif defined(AK_OS_GNU_HURD) || defined(AK_OS_PLAN9)
     return Error::from_errno(ENOTSUP);
 #else
     struct ucred creds = {};
@@ -527,7 +527,7 @@ ErrorOr<pid_t> LocalSocket::peer_pid() const
 #elif defined(AK_OS_SOLARIS)
     TRY(System::getsockopt(m_helper.fd(), SOL_SOCKET, SO_RECVUCRED, &creds, &creds_size));
     return ucred_getpid(creds);
-#elif !defined(AK_OS_GNU_HURD)
