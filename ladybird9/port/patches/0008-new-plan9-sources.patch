+#
+# Plan 9 GUI framework. `ladybird` drives headless modes via the base
+# WebView::Application (M4), and — when run without --headless under the
+# gl9win2 presenter — an interactive Plan9WebView (M5): fd 0 carries 16-byte
+# input records, fd 1 carries GL9B (BGRA) frames.
+#
+
+add_executable(ladybird main.cpp Application.cpp Plan9WebView.cpp Plan9BrowserWindow.cpp)
+target_link_libraries(ladybird PRIVATE LibWebView LibWeb LibGfx LibCore LibMain)
+
+# Copies runtime resources (themes, fonts, about pages) to share/Lagom and
+# defines ladybird_build_resource_files, like the other frameworks do.
+create_ladybird_bundle(ladybird)
diff --git a/UI/Plan9/Plan9BrowserWindow.cpp b/UI/Plan9/Plan9BrowserWindow.cpp
new file mode 100644
index 0000000000..9c94545327
--- /dev/null
+++ b/UI/Plan9/Plan9BrowserWindow.cpp
@@ -0,0 +1,145 @@
+/*
+ * Copyright (c) 2026, the Ladybird developers.
+ *
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include <UI/Plan9/Plan9BrowserWindow.h>
+
+#include <unistd.h>
+
+namespace Ladybird {
+
+static void write_all(int fd, void const* buf, size_t n)
+{
+    auto const* p = static_cast<u8 const*>(buf);
+    while (n > 0) {
+        auto w = ::write(fd, p, n);
+        if (w <= 0)
+            return;
+        p += w;
+        n -= static_cast<size_t>(w);
+    }
+}
+
+Plan9BrowserWindow::Plan9BrowserWindow(Core::AnonymousBuffer theme, Web::DevicePixelSize window_size, int frame_fd)
+    : m_theme(move(theme))
+    , m_window_size(window_size)
+    , m_frame_fd(frame_fd)
+{
+}
+
+void Plan9BrowserWindow::wire_view(Plan9WebView& view)
+{
+    view.on_chrome_state_changed = [this]() { emit_tab_list(); };
+    view.on_quit = [this]() {
+        if (on_quit)
+            on_quit();
+    };
+}
+
+void Plan9BrowserWindow::open_initial_tab(StringView url)
+{
+    new_tab(url);
+}
+
+void Plan9BrowserWindow::new_tab(StringView url)
+{
+    if (!m_tabs.is_empty())
+        m_tabs[m_active]->set_active(false);
+
+    auto view = Plan9WebView::create(m_theme, m_window_size, m_frame_fd);
+    wire_view(*view);
+    m_tabs.append(move(view));
+    m_active = m_tabs.size() - 1;
+
+    auto& active = *m_tabs[m_active];
+    active.set_active(true); // no-op if already (new views default active); ensures state
+    active.navigate(url.is_empty() ? "about:blank"sv : url);
+    emit_tab_list();
+}
+
+void Plan9BrowserWindow::switch_tab(size_t index)
+{
+    if (index >= m_tabs.size() || index == m_active)
+        return;
+    m_tabs[m_active]->set_active(false);
+    m_active = index;
+    m_tabs[m_active]->set_active(true); // re-presents the cached frame + chrome state
+    emit_tab_list();
+}
+
+void Plan9BrowserWindow::close_tab(size_t index)
+{
+    if (index >= m_tabs.size())
+        return;
+
+    // Last tab closed → quit the browser.
+    if (m_tabs.size() == 1) {
+        if (on_quit)
+            on_quit();
+        return;
+    }
+
+    bool closing_active = index == m_active;
+    m_tabs.remove(index);
+    if (m_active >= m_tabs.size())
+        m_active = m_tabs.size() - 1;
+    else if (index < m_active)
+        m_active -= 1;
+
+    if (closing_active) {
+        // The new active tab must take over the surface.
+        m_tabs[m_active]->set_active(true);
+    }
+    emit_tab_list();
+}
+
+void Plan9BrowserWindow::handle_command(u8 subcommand, u32 tab_index, StringView text)
+{
+    switch (subcommand) {
+    case 1: active_view().go_back(); break;
+    case 2: active_view().go_forward(); break;
+    case 3: active_view().reload_page(); break;
+    case 4: active_view().stop(); break;
+    case 5: new_tab({}); break;
+    case 6: switch_tab(tab_index); break;
+    case 7: close_tab(tab_index); break;
+    case 8: active_view().navigate(text); break;
+    default: break;
+    }
+}
+
+void Plan9BrowserWindow::feed_event(u8 type, u8 state, u16 modifiers, u32 a, u32 b)
+{
+    active_view().feed_event(type, state, modifiers, a, b);
+}
+
+void Plan9BrowserWindow::emit_tab_list()
+{
+    // GL9K: magic + u32be count + u32be active + per tab (u32be len + UTF-8 title).
+    auto put_be32 = [](Vector<u8>& v, u32 x) {
+        v.append(static_cast<u8>(x >> 24));
+        v.append(static_cast<u8>(x >> 16));
+        v.append(static_cast<u8>(x >> 8));
+        v.append(static_cast<u8>(x));
+    };
+    Vector<u8> buf;
+    buf.append('G');
+    buf.append('L');
+    buf.append('9');
+    buf.append('K');
+    put_be32(buf, static_cast<u32>(m_tabs.size()));
+    put_be32(buf, static_cast<u32>(m_active));
+    for (auto& tab : m_tabs) {
+        auto title = tab->current_title();
+        if (title.is_empty())
+            title = "New Tab";
+        put_be32(buf, static_cast<u32>(title.length()));
+        for (auto c : title.bytes())
+            buf.append(c);
+    }
+    write_all(m_frame_fd, buf.data(), buf.size());
+}
+
+}
diff --git a/UI/Plan9/Plan9BrowserWindow.h b/UI/Plan9/Plan9BrowserWindow.h
new file mode 100644
index 0000000000..67d360f7ae
--- /dev/null
+++ b/UI/Plan9/Plan9BrowserWindow.h
@@ -0,0 +1,55 @@
+/*
+ * Copyright (c) 2026, the Ladybird developers.
+ *
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#pragma once
+
+#include <AK/Vector.h>
+#include <LibGfx/Size.h>
+#include <UI/Plan9/Plan9WebView.h>
+
+namespace Ladybird {
+
+// The Plan 9 analog of UI/Qt's BrowserWindow: owns the browser's tabs (one
+// Plan9WebView each), tracks the active one, and is the single writer to the
+// gl9win2 presenter's frame pipe. Only the active tab streams frames + its
+// URL/nav state; the tab strip (GL9K) is re-emitted whenever the set of tabs or
+// a title changes. Chrome commands from the presenter (address bar, nav buttons,
+// tab strip) are routed here.
+class Plan9BrowserWindow {
+    AK_MAKE_NONCOPYABLE(Plan9BrowserWindow);
+    AK_MAKE_NONMOVABLE(Plan9BrowserWindow);
+
+public:
+    Plan9BrowserWindow(Core::AnonymousBuffer theme, Web::DevicePixelSize window_size, int frame_fd);
+
+    Plan9WebView& active_view() { return *m_tabs[m_active]; }
+
+    // Presenter command dispatch (type-8 records). `text` only for navigate.
+    void handle_command(u8 subcommand, u32 tab_index, StringView text);
+
+    // Non-chrome input (mouse/key/scroll/resize/focus/quit) → active tab.
+    void feed_event(u8 type, u8 state, u16 modifiers, u32 a, u32 b);
+
+    // Open the first tab (loads `url`, or a blank page if empty).
+    void open_initial_tab(StringView url);
+
+    Function<void()> on_quit;
+
+private:
+    void new_tab(StringView url);
+    void switch_tab(size_t index);
+    void close_tab(size_t index);
+    void wire_view(Plan9WebView&);
+    void emit_tab_list();
+
+    Core::AnonymousBuffer m_theme;
+    Web::DevicePixelSize m_window_size;
+    int m_frame_fd { 1 };
+    Vector<NonnullOwnPtr<Plan9WebView>> m_tabs;
+    size_t m_active { 0 };
+};
+
+}
diff --git a/UI/Plan9/Plan9WebView.cpp b/UI/Plan9/Plan9WebView.cpp
new file mode 100644
index 0000000000..a2d0b8b7b2
--- /dev/null
+++ b/UI/Plan9/Plan9WebView.cpp
@@ -0,0 +1,290 @@
+/*
+ * Copyright (c) 2026, the Ladybird developers.
+ *
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include <UI/Plan9/Plan9WebView.h>
+
+#include <AK/Utf16String.h>
+#include <LibGfx/Bitmap.h>
+#include <LibGfx/SharedImageBuffer.h>
+#include <LibWeb/HTML/VisibilityState.h>
+#include <LibWebView/Menu.h>
+#include <LibWebView/URL.h>
+
+#include <unistd.h>
+
+namespace Ladybird {
+
+using Web::UIEvents::KeyCode;
+using Web::UIEvents::KeyModifier;
+using Web::UIEvents::MouseButton;
+
+NonnullOwnPtr<Plan9WebView> Plan9WebView::create(Core::AnonymousBuffer theme, Web::DevicePixelSize window_size, int frame_fd)
+{
+    auto view = adopt_own(*new Plan9WebView(move(theme), window_size, frame_fd));
+    view->initialize_client(CreateNewClient::Yes);
+    // A hidden page's render pipeline is throttled; mark visible and push the
+    // initial viewport so the page lays out and paints (headless does this via
+    // take_screenshot, but the interactive path relies on natural paints).
+    view->set_system_visibility_state(Web::HTML::VisibilityState::Visible);
+    view->handle_resize();
+
+    // Push chrome state (URL + reload/stop + back/forward) to the presenter as it
+    // changes; title changes ask the coordinator to re-emit the tab list (GL9K).
+    auto* raw = view.ptr();
+    raw->on_url_change = [raw](auto const&) { raw->emit_chrome_state(); };
+    raw->on_load_start = [raw]() { raw->emit_chrome_state(); };
+    raw->on_load_finish = [raw](auto const&) {
+        raw->emit_chrome_state();
+        if (raw->on_chrome_state_changed)
+            raw->on_chrome_state_changed();
+    };
+    raw->on_loading_state_change = [raw](bool) { raw->emit_chrome_state(); };
+    raw->on_title_change = [raw](auto const&) {
+        if (raw->on_chrome_state_changed)
+            raw->on_chrome_state_changed();
+    };
+    return view;
+}
+
+Plan9WebView::Plan9WebView(Core::AnonymousBuffer theme, Web::DevicePixelSize size, int frame_fd)
+    : WebView::HeadlessWebView(move(theme), size)
+    , m_frame_fd(frame_fd)
+{
+    // Stream every painted frame to the presenter.
+    on_ready_to_paint = [this] { present(); };
+}
+
+static void write_all(int fd, void const* buf, size_t n)
+{
+    auto const* p = static_cast<u8 const*>(buf);
+    while (n > 0) {
+        auto w = ::write(fd, p, n);
+        if (w <= 0)
+            return; // presenter gone or would block indefinitely; drop the rest
+        p += w;
+        n -= static_cast<size_t>(w);
+    }
+}
+
+// Emit a length-prefixed record: 4-byte magic + u32be len + UTF-8 bytes.
+static void write_lp_record(int fd, char const (&magic)[5], StringView text)
+{
+    u32 len = static_cast<u32>(text.length());
+    u8 hdr[8] = {
+        static_cast<u8>(magic[0]), static_cast<u8>(magic[1]), static_cast<u8>(magic[2]), static_cast<u8>(magic[3]),
+        static_cast<u8>(len >> 24), static_cast<u8>(len >> 16), static_cast<u8>(len >> 8), static_cast<u8>(len)
+    };
+    write_all(fd, hdr, sizeof hdr);
+    write_all(fd, text.characters_without_null_termination(), len);
+}
+
+void Plan9WebView::present()
+{
+    if (!m_active)
+        return;
+    if (!m_client_state.has_usable_bitmap || !m_client_state.front_bitmap.shared_image_buffer)
+        return;
+
+    auto bitmap = m_client_state.front_bitmap.shared_image_buffer->bitmap();
+    u32 w = static_cast<u32>(bitmap->width());
+    u32 h = static_cast<u32>(bitmap->height());
+
+    // GL9B: BGRA8888 full frame (== Plan 9 ARGB32; gl9win2 converts on blit).
+    u8 hdr[12] = {
+        'G', 'L', '9', 'B',
+        static_cast<u8>(w >> 24), static_cast<u8>(w >> 16), static_cast<u8>(w >> 8), static_cast<u8>(w),
+        static_cast<u8>(h >> 24), static_cast<u8>(h >> 16), static_cast<u8>(h >> 8), static_cast<u8>(h)
+    };
+    write_all(m_frame_fd, hdr, sizeof hdr);
+
+    // Row-by-row: the presenter reads w*h*4 contiguous bytes, and the bitmap's
+    // pitch may exceed w*4 (padding), so send exactly the visible width.
+    for (u32 y = 0; y < h; ++y)
+        write_all(m_frame_fd, bitmap->scanline_u8(static_cast<int>(y)), static_cast<size_t>(w) * 4);
+}
+
+// Presenter modifier bitmask (bit0 shift, bit1 ctrl, bit2 alt, bit3 super) ->
+// Web KeyModifier (whose bit assignments differ).
+static KeyModifier map_mods(u16 m)
+{
+    int r = KeyModifier::Mod_None;
+    if (m & 1)
+        r |= KeyModifier::Mod_Shift;
+    if (m & 2)
+        r |= KeyModifier::Mod_Ctrl;
+    if (m & 4)
+        r |= KeyModifier::Mod_Alt;
+    if (m & 8)
+        r |= KeyModifier::Mod_Super;
+    return static_cast<KeyModifier>(r);
+}
+
+void Plan9WebView::dispatch_mouse(Web::MouseEvent::Type type, MouseButton changed_button, u16 modifiers, double wheel_y)
+{
+    Web::MouseEvent event;
+    event.type = type;
+    event.position = Web::DevicePixelPoint { m_mouse.x(), m_mouse.y() };
+    event.screen_position = event.position;
+    event.button = changed_button;
+    event.buttons = m_buttons;
+    event.modifiers = map_mods(modifiers);
+    event.wheel_delta_y = wheel_y;
+    if (type == Web::MouseEvent::Type::MouseDown) {
+        // Qt defaults: 400ms double-click interval, 10px start-drag distance.
+        static constexpr auto double_click_interval = AK::Duration::from_milliseconds(400);
+        static constexpr int start_drag_distance = 10;
+        auto now = MonotonicTime::now();
+        auto d = m_mouse.absolute_relative_distance_to(m_last_click_position);
+        int manhattan = d.x() + d.y();
+        if (now - m_last_click_time < double_click_interval && manhattan < start_drag_distance)
+            ++m_click_count;
+        else
+            m_click_count = 1;
+        m_last_click_time = now;
+        m_last_click_position = m_mouse;
+    }
+    if (type == Web::MouseEvent::Type::MouseDown || type == Web::MouseEvent::Type::MouseUp)
+        event.click_count = m_click_count;
+    enqueue_input_event(move(event));
+}
+
+void Plan9WebView::dispatch_key(bool down, u32 rune, u16 modifiers)
+{
+    // Plan 9 key runes (/sys/include/keyboard.h; see alacritty9/PROTOCOL.md).
+    KeyCode key = KeyCode::Key_Invalid;
+    u32 code_point = 0;
+    bool printable = false;
+
+    switch (rune) {
+    case 0x08: key = KeyCode::Key_Backspace; break;
+    case 0x09: key = KeyCode::Key_Tab; break;
+    case 0x0A:
+    case 0x0D: key = KeyCode::Key_Return; break;
+    case 0x1B: key = KeyCode::Key_Escape; break;
+    case 0x7F: key = KeyCode::Key_Delete; break;
+    case 0x80: key = KeyCode::Key_Down; break;    // yes, Kdown is 0x80 on Plan 9
+    case 0xF00D: key = KeyCode::Key_Home; break;
+    case 0xF00E: key = KeyCode::Key_Up; break;
+    case 0xF00F: key = KeyCode::Key_PageUp; break;
+    case 0xF011: key = KeyCode::Key_Left; break;
+    case 0xF012: key = KeyCode::Key_Right; break;
+    case 0xF013: key = KeyCode::Key_PageDown; break;
+    case 0xF014: key = KeyCode::Key_Insert; break;
+    case 0xF018: key = KeyCode::Key_End; break;
+    default:
+        if (rune >= 0x20 && rune < 0xF000) {
+            code_point = rune;
+            printable = true;
+        }
+        break;
+    }
+
+    Web::KeyEvent event;
+    event.type = down ? Web::KeyEvent::Type::KeyDown : Web::KeyEvent::Type::KeyUp;
+    event.key = key;
+    event.modifiers = map_mods(modifiers);
+    event.code_point = code_point;
+    event.should_insert_text = printable && down;
+    enqueue_input_event(move(event));
+}
+
+void Plan9WebView::feed_event(u8 type, u8 state, u16 modifiers, u32 a, u32 b)
+{
+    switch (type) {
+    case 1: // key
+        dispatch_key(state == 1, a, modifiers);
+        break;
+    case 2: // mouse move
+        m_mouse = { static_cast<int>(a), static_cast<int>(b) };
+        dispatch_mouse(Web::MouseEvent::Type::MouseMove, MouseButton::None, modifiers);
+        break;
+    case 3: { // mouse button (a: 1=left, 2=middle, 3=right)
+        MouseButton btn = a == 1 ? MouseButton::Primary : a == 2 ? MouseButton::Middle
+                                                                 : MouseButton::Secondary;
+        if (state == 1)
+            m_buttons = static_cast<MouseButton>(m_buttons | btn);
+        else
+            m_buttons = static_cast<MouseButton>(m_buttons & ~btn);
+        dispatch_mouse(state == 1 ? Web::MouseEvent::Type::MouseDown : Web::MouseEvent::Type::MouseUp, btn, modifiers);
+        break;
+    }
+    case 4: {
+        // scroll: a = notch delta (i32, + = up); gl9win2 emits +/-1 per detent.
+        // wheel_delta_y is in CSS px, + = down. Match the Qt/AppKit feel: one notch
+        // = wheelScrollLines(3 default) * scroll_step_size(40px) = 120 CSS px.
+        static constexpr double px_per_notch = 120;
+        dispatch_mouse(Web::MouseEvent::Type::MouseWheel, MouseButton::None, modifiers, -static_cast<double>(static_cast<i32>(a)) * px_per_notch);
+        break;
+    }
+    case 5: // resize
+        if (on_resize_window)
+            on_resize_window(Gfx::IntSize { static_cast<int>(a), static_cast<int>(b) });
+        break;
+    case 6: { // focus: state 1 = gained, 0 = lost
+        bool focused = state == 1;
+        client().async_set_has_focus(m_client_state.page_index, focused);
+        // The presenter has no separate mouse-leave record; losing focus is our
+        // proxy for the pointer leaving, so clear stale :hover state.
+        if (!focused)
+            dispatch_mouse(Web::MouseEvent::Type::MouseLeave, MouseButton::None, modifiers);
+        break;
+    }
+    case 7: // quit
+        if (on_quit)
+            on_quit();
+        break;
+    }
+}
+
+// ---- Chrome commands (driven by the presenter's address bar / nav buttons) ----
+
+void Plan9WebView::navigate(StringView text)
+{
+    if (auto url = WebView::sanitize_url(text); url.has_value())
+        load(url.release_value());
+    else
+        load_navigation_error_page(text);
+}
+
+void Plan9WebView::go_back() { (void)traverse_the_history_by_delta(-1); }
+void Plan9WebView::go_forward() { (void)traverse_the_history_by_delta(1); }
+void Plan9WebView::reload_page() { reload(); }
+void Plan9WebView::stop() { stop_loading(); }
+
+ByteString Plan9WebView::current_url() const { return url().serialize().to_byte_string(); }
+ByteString Plan9WebView::current_title() const { return title().to_byte_string(); }
+
+void Plan9WebView::set_active(bool active)
+{
+    if (m_active == active)
+        return;
+    m_active = active;
+    if (m_active) {
+        // Newly-active tab: push its current frame + chrome state to the presenter.
+        present();
+        emit_chrome_state();
+    }
+}
+
+void Plan9WebView::emit_chrome_state()
+{
+    if (!m_active)
+        return;
+    // GL9U: the current URL for the address bar.
+    auto url_bytes = current_url();
+    write_lp_record(m_frame_fd, "GL9U", url_bytes.view());
+    // GL9L: loading + back/forward-enabled, driving the reload/stop swap + buttons.
+    u8 rec[8] = {
+        'G', 'L', '9', 'L',
+        static_cast<u8>(is_loading() ? 1 : 0),
+        static_cast<u8>(navigate_back_action().enabled() ? 1 : 0),
+        static_cast<u8>(navigate_forward_action().enabled() ? 1 : 0),
+        0
+    };
+    write_all(m_frame_fd, rec, sizeof rec);
+}
+
+}
