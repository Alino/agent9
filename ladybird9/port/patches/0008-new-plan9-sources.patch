+// AK_OS_PLAN9: FFmpeg is deferred on Plan 9 (see ladybird9/parity/deferrals.md).
+// This TU stands in for the real FFmpeg sources: it implements only the
+// factory entry points the rest of LibMedia calls, each reporting that the
+// decoder is unavailable. <video>/<audio> decode simply fails gracefully.
+//
+// SPDX-License-Identifier: BSD-2-Clause
+
+#include <LibMedia/FFmpeg/FFmpegAudioConverter.h>
+#include <LibMedia/FFmpeg/FFmpegAudioDecoder.h>
+#include <LibMedia/FFmpeg/FFmpegDemuxer.h>
+#include <LibMedia/FFmpeg/FFmpegVideoDecoder.h>
+
+namespace Media::FFmpeg {
+
+DecoderErrorOr<NonnullRefPtr<FFmpegDemuxer>> FFmpegDemuxer::from_stream(NonnullRefPtr<MediaStream> const&)
+{
+    return DecoderError::with_description(DecoderErrorCategory::NotImplemented, "FFmpeg is not available on Plan 9"sv);
+}
+
+// The factories above never construct, so no instance of these classes can
+// exist: everything below only satisfies the vtables that the (smart-pointer
+// instantiated) destructors emit.
+
+DecoderErrorOr<NonnullOwnPtr<FFmpegVideoDecoder>> FFmpegVideoDecoder::try_create(CodecID, ReadonlyBytes)
+{
+    return DecoderError::with_description(DecoderErrorCategory::NotImplemented, "FFmpeg is not available on Plan 9"sv);
+}
+
+FFmpegVideoDecoder::~FFmpegVideoDecoder() = default;
+
+DecoderErrorOr<void> FFmpegVideoDecoder::receive_coded_data(AK::Duration, AK::Duration, ReadonlyBytes, Optional<AK::Duration>)
+{
+    VERIFY_NOT_REACHED();
+}
+
+void FFmpegVideoDecoder::signal_end_of_stream()
+{
+    VERIFY_NOT_REACHED();
+}
+
+DecoderErrorOr<NonnullRefPtr<VideoFrame>> FFmpegVideoDecoder::get_decoded_frame(CodingIndependentCodePoints const&)
+{
+    VERIFY_NOT_REACHED();
+}
+
+void FFmpegVideoDecoder::flush()
+{
+    VERIFY_NOT_REACHED();
+}
+
+DecoderErrorOr<NonnullOwnPtr<FFmpegAudioDecoder>> FFmpegAudioDecoder::try_create(CodecID, Audio::SampleSpecification const&, ReadonlyBytes)
+{
+    return DecoderError::with_description(DecoderErrorCategory::NotImplemented, "FFmpeg is not available on Plan 9"sv);
+}
+
+FFmpegAudioDecoder::~FFmpegAudioDecoder() = default;
+
+DecoderErrorOr<void> FFmpegAudioDecoder::receive_coded_data(AK::Duration, ReadonlyBytes)
+{
+    VERIFY_NOT_REACHED();
+}
+
+void FFmpegAudioDecoder::signal_end_of_stream()
+{
+    VERIFY_NOT_REACHED();
+}
+
+DecoderErrorOr<void> FFmpegAudioDecoder::write_next_block(AudioBlock&)
+{
+    VERIFY_NOT_REACHED();
+}
+
+void FFmpegAudioDecoder::flush()
+{
+    VERIFY_NOT_REACHED();
+}
+
+ErrorOr<NonnullOwnPtr<FFmpegAudioConverter>> FFmpegAudioConverter::try_create()
+{
+    return Error::from_string_literal("FFmpeg is not available on Plan 9");
+}
+
+FFmpegAudioConverter::~FFmpegAudioConverter() = default;
+
+ErrorOr<void> FFmpegAudioConverter::set_output_sample_specification(Audio::SampleSpecification)
+{
+    VERIFY_NOT_REACHED();
+}
+
+ErrorOr<void> FFmpegAudioConverter::convert(AudioBlock&)
+{
+    VERIFY_NOT_REACHED();
+}
+
+}
