@@ -0,0 +1,77 @@
+/*
+ * Copyright (c) 2024, Andrew Kaster <andrew@ladybird.org>
+ * Copyright (c) 2026, the Ladybird developers.
+ *
+ * SPDX-License-Identifier: BSD-2-Clause
+ *
+ * Plan 9 transport: byte stream over a socketpair (a full-duplex Plan 9
+ * pipe); attachments travel IN-BAND like TransportSocketWindows — shared-
+ * memory buffers as named-segment {name, offset, length} triples, any other
+ * fd via a posted /srv entry the receiver opens and removes. No SCM_RIGHTS,
+ * no fd-retention protocol, no peer pid needed (names are global).
+ */
+
+#pragma once
+
+#include <AK/Queue.h>
+#include <LibCore/Socket.h>
+#include <LibIPC/Attachment.h>
+#include <LibIPC/Forward.h>
+#include <LibIPC/ReceivedMessageBytes.h>
+#include <LibIPC/TransportHandle.h>
+
+namespace IPC {
+
+class TransportPlan9 {
+    AK_MAKE_NONCOPYABLE(TransportPlan9);
+    AK_MAKE_DEFAULT_MOVABLE(TransportPlan9);
+
+public:
+    struct Paired {
+        NonnullOwnPtr<TransportPlan9> local;
+        TransportHandle remote_handle;
+    };
+    static ErrorOr<Paired> create_paired();
+    static ErrorOr<NonnullOwnPtr<TransportPlan9>> from_socket(NonnullOwnPtr<Core::LocalSocket> socket);
+
+    explicit TransportPlan9(NonnullOwnPtr<Core::LocalSocket> socket);
+
+    // NB: no set_peer_pid — like the Unix TransportSocket. Its presence is what
+    // the `if constexpr (requires { transport().set_peer_pid(0); })` guards in
+    // HelperProcess use to decide whether to run the peer-pid `init_transport`
+    // handshake. Plan 9 addresses shm/fd handles by global name, so no peer pid
+    // is needed; and the init_transport HANDLER is #ifdef AK_OS_WINDOWS
+    // (VERIFY_NOT_REACHED elsewhere), so sending it would deadlock/crash the
+    // helper. Omitting the method makes those guards false — matching Unix.
+    void set_up_read_hook(Function<void()>);
+    bool is_open() const;
+    void close();
+    void close_after_sending_all_pending_messages();
+
+    void wait_until_readable();
+
+    void post_message(MessageDataType, Vector<Attachment>& attachments);
+
+    enum class ShouldShutdown {
+        No,
+        Yes,
+    };
+    struct Message {
+        ReceivedMessageBytes bytes;
+        Queue<Attachment> attachments;
+    };
+    ShouldShutdown read_as_many_messages_as_possible_without_blocking(Function<void(Message&&)>&&);
+
+    ErrorOr<TransportHandle> release_for_transfer();
+
+private:
+    ErrorOr<Vector<u8>> serialize_attachments(Vector<Attachment>&);
+    Attachment deserialize_attachment(ReadonlyBytes&);
+    ErrorOr<void> transfer(ReadonlyBytes);
+
+private:
+    NonnullOwnPtr<Core::LocalSocket> m_socket;
+    ByteBuffer m_unprocessed_bytes;
+};
+
+}
