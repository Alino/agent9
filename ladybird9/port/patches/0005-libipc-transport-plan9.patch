+/*
+ * Copyright (c) 2024, Andrew Kaster <andrew@ladybird.org>
+ * Copyright (c) 2025, stasoid <stasoid@yahoo.com>
+ * Copyright (c) 2026, the Ladybird developers.
+ *
+ * SPDX-License-Identifier: BSD-2-Clause
+ *
+ * Structure mirrors TransportSocketWindows (the shipped in-band-attachment
+ * transport); only the attachment carriers differ:
+ *   Segment — the fd is a cc9 shared-memory handle (#g named global segment,
+ *             how anon_create() is realized on Plan 9): serialize its
+ *             {name, offset, length}; the receiver re-imports by name and
+ *             mmap(MAP_SHARED) attaches the same physical pages.
+ *   Srv     — any other fd: post it under a fresh /srv name (srv(3) holds a
+ *             reference to the channel itself); the receiver opens the name
+ *             — acquiring the same open file, SCM_RIGHTS semantics — and
+ *             removes the entry. Each send posts a fresh entry, so multi-hop
+ *             forwarding re-serializes safely.
+ */
+
+#include <AK/ByteReader.h>
+#include <AK/Checked.h>
+#include <AK/ScopeGuard.h>
+#include <AK/Types.h>
+#include <LibCore/System.h>
+#include <LibIPC/File.h>
+#include <LibIPC/Limits.h>
+#include <LibIPC/TransportHandle.h>
+#include <LibIPC/TransportPlan9.h>
+
+#include <errno.h>
+#include <fcntl.h>
+#include <poll.h>
+#include <stdio.h>
+#include <unistd.h>
+
+// cc9 runtime (shm9.c + fs.c): shared-segment handles and /srv posting.
+extern "C" {
+int cc9_shm_export(int fd, char* name, unsigned long* offset, unsigned long* len);
+int cc9_shm_import(char const* name, unsigned long offset, unsigned long len);
+long cc9_srv_post(char const* name, int fd);
+long cc9_srv_remove(char const* name);
+}
+
+namespace IPC {
+
+static constexpr size_t CC9_SHM_NAMELEN = 28;
+
+enum class Plan9AttachmentKind : u8 {
+    Segment = 0,
+    Srv = 1,
+};
+
+// kind + namelen + name + offset + length
+static constexpr size_t MAX_SERIALIZED_ATTACHMENT_SIZE = 1 + 1 + CC9_SHM_NAMELEN + sizeof(u64) + sizeof(u64);
+static constexpr size_t MAX_ATTACHMENT_DATA_SIZE = MAX_MESSAGE_FD_COUNT * MAX_SERIALIZED_ATTACHMENT_SIZE;
+
+ErrorOr<NonnullOwnPtr<TransportPlan9>> TransportPlan9::from_socket(NonnullOwnPtr<Core::LocalSocket> socket)
+{
+    return make<TransportPlan9>(move(socket));
+}
+
+ErrorOr<TransportPlan9::Paired> TransportPlan9::create_paired()
+{
+    int fds[2] {};
+    TRY(Core::System::socketpair(AF_LOCAL, SOCK_STREAM, 0, fds));
+
+    ArmedScopeGuard guard_fd_0 { [&] { MUST(Core::System::close(fds[0])); } };
+    ArmedScopeGuard guard_fd_1 { [&] { MUST(Core::System::close(fds[1])); } };
+
+    auto socket0 = TRY(Core::LocalSocket::adopt_fd(fds[0]));
+    guard_fd_0.disarm();
+    TRY(socket0->set_close_on_exec(true));
+    TRY(socket0->set_blocking(false));
+
+    TRY(Core::System::set_close_on_exec(fds[1], true));
+    guard_fd_1.disarm();
+
+    return Paired {
+        make<TransportPlan9>(move(socket0)),
+        TransportHandle { File::adopt_fd(fds[1]) },
+    };
+}
+
+TransportPlan9::TransportPlan9(NonnullOwnPtr<Core::LocalSocket> socket)
+    : m_socket(move(socket))
+{
+}
+
+void TransportPlan9::set_up_read_hook(Function<void()> hook)
+{
+    VERIFY(m_socket->is_open());
+    m_socket->on_ready_to_read = move(hook);
+}
+
+bool TransportPlan9::is_open() const
+{
+    return m_socket->is_open();
+}
+
+void TransportPlan9::close()
+{
+    m_socket->close();
+}
+
+void TransportPlan9::close_after_sending_all_pending_messages()
+{
+    // transfer() is synchronous: nothing can be pending here.
+    close();
+}
+
+void TransportPlan9::wait_until_readable()
+{
+    auto readable = MUST(m_socket->can_read_without_blocking(-1));
+    VERIFY(readable);
+}
+
+// Maximum size of accumulated unprocessed bytes before we disconnect the peer
+static constexpr size_t MAX_UNPROCESSED_BUFFER_SIZE = 128 * MiB;
+
+struct MessageHeader {
+    u32 payload_size { 0 };
+    u32 attachment_data_size { 0 };
+    u32 attachment_count { 0 };
+};
+
+ErrorOr<Vector<u8>> TransportPlan9::serialize_attachments(Vector<Attachment>& attachments)
+{
+    if (attachments.is_empty())
+        return Vector<u8> {};
+
+    static Atomic<u32> s_srv_sequence { 0 };
+
+    Vector<u8> serialized_attachments;
+    TRY(serialized_attachments.try_ensure_capacity(attachments.size() * MAX_SERIALIZED_ATTACHMENT_SIZE));
+
+    for (auto& attachment : attachments) {
+        int fd = attachment.to_fd();
+        ScopeGuard close_original_fd = [&] {
+            if (fd != -1)
+                (void)Core::System::close(fd);
+        };
+
+        char name[64] = {};
+        unsigned long offset = 0;
+        unsigned long length = 0;
+        if (cc9_shm_export(fd, name, &offset, &length) == 0) {
+            // Shared-memory handle: travels by segment name. The #g entry
+            // outlives our fd; the shm sweeper collects it once unattached.
+            TRY(serialized_attachments.try_append(to_underlying(Plan9AttachmentKind::Segment)));
+            u8 name_length = static_cast<u8>(strlen(name));
+            TRY(serialized_attachments.try_append(name_length));
+            TRY(serialized_attachments.try_append(reinterpret_cast<u8 const*>(name), name_length));
+            u64 wire_offset = offset;
+            u64 wire_length = length;
+            TRY(serialized_attachments.try_append(reinterpret_cast<u8 const*>(&wire_offset), sizeof(wire_offset)));
+            TRY(serialized_attachments.try_append(reinterpret_cast<u8 const*>(&wire_length), sizeof(wire_length)));
+        } else {
+            // Any other open file: post it under /srv; the entry itself
+            // retains the channel, so our fd can close immediately.
+            (void)snprintf(name, sizeof(name), "lb.%d.%u", ::getpid(), s_srv_sequence.fetch_add(1) + 1);
+            if (cc9_srv_post(name, fd) < 0)
+                return Error::from_string_literal("TransportPlan9: /srv post failed");
+            TRY(serialized_attachments.try_append(to_underlying(Plan9AttachmentKind::Srv)));
+            u8 name_length = static_cast<u8>(strlen(name));
+            TRY(serialized_attachments.try_append(name_length));
+            TRY(serialized_attachments.try_append(reinterpret_cast<u8 const*>(name), name_length));
+        }
+    }
+
+    attachments.clear();
+    return serialized_attachments;
+}
+
+Attachment TransportPlan9::deserialize_attachment(ReadonlyBytes& serialized_bytes)
+{
+    VERIFY(serialized_bytes.size() >= 2);
+
+    auto kind = static_cast<Plan9AttachmentKind>(serialized_bytes[0]);
+    u8 name_length = serialized_bytes[1];
+    serialized_bytes = serialized_bytes.slice(2);
+    VERIFY(serialized_bytes.size() >= name_length);
+
+    char name[64] = {};
+    VERIFY(name_length < sizeof(name));
+    memcpy(name, serialized_bytes.data(), name_length);
+    serialized_bytes = serialized_bytes.slice(name_length);
+
+    switch (kind) {
+    case Plan9AttachmentKind::Segment: {
+        VERIFY(serialized_bytes.size() >= 2 * sizeof(u64));
+        u64 offset = 0;
+        u64 length = 0;
+        ByteReader::load(serialized_bytes.data(), offset);
+        ByteReader::load(serialized_bytes.data() + sizeof(u64), length);
+        serialized_bytes = serialized_bytes.slice(2 * sizeof(u64));
+        int fd = cc9_shm_import(name, offset, length);
+        VERIFY(fd >= 0);
+        return Attachment::from_fd(fd);
+    }
+    case Plan9AttachmentKind::Srv: {
+        char path[80];
+        (void)snprintf(path, sizeof(path), "/srv/%s", name);
+        int fd = ::open(path, O_RDWR);
+        VERIFY(fd >= 0);
+        // Receiver removes: each send posts a fresh entry, so multi-hop and
+        // multi-peer sharing both re-post — never reuse a name.
+        (void)cc9_srv_remove(name);
+        return Attachment::from_fd(fd);
+    }
+    }
+
+    VERIFY_NOT_REACHED();
+}
+
+void TransportPlan9::post_message(MessageDataType bytes, Vector<Attachment>& attachments)
+{
+    VERIFY(bytes.size() <= MAX_MESSAGE_PAYLOAD_SIZE);
+    VERIFY(attachments.size() <= MAX_MESSAGE_FD_COUNT);
+
+    auto attachment_count = attachments.size();
+    auto serialized_attachments = MUST(serialize_attachments(attachments));
+    VERIFY(serialized_attachments.size() <= MAX_ATTACHMENT_DATA_SIZE);
+
+    Vector<u8> message_buffer;
+    MUST(message_buffer.try_resize(sizeof(MessageHeader) + serialized_attachments.size() + bytes.size()));
+
+    MessageHeader header {
+        .payload_size = static_cast<u32>(bytes.size()),
+        .attachment_data_size = static_cast<u32>(serialized_attachments.size()),
+        .attachment_count = static_cast<u32>(attachment_count),
+    };
+    memcpy(message_buffer.data(), &header, sizeof(header));
+
+    auto* serialized_attachment_storage = message_buffer.data() + sizeof(MessageHeader);
+    if (!serialized_attachments.is_empty())
+        memcpy(serialized_attachment_storage, serialized_attachments.data(), serialized_attachments.size());
+
+    auto* payload_storage = serialized_attachment_storage + serialized_attachments.size();
+    if (!bytes.is_empty())
+        memcpy(payload_storage, bytes.data(), bytes.size());
+
+    MUST(transfer(message_buffer.span()));
+}
+
+ErrorOr<void> TransportPlan9::transfer(ReadonlyBytes bytes_to_write)
+{
+    while (!bytes_to_write.is_empty()) {
+
+        ErrorOr<size_t> maybe_nwritten = m_socket->write_some(bytes_to_write);
+
+        if (maybe_nwritten.is_error()) {
+            auto error = maybe_nwritten.release_error();
+            if (error.code() != EWOULDBLOCK && error.code() != EAGAIN)
+                return error;
+
+            // cc9's write rings report honest POLLOUT: wait for space.
+            struct pollfd pollfd = {
+                .fd = m_socket->fd().value(),
+                .events = POLLOUT,
+                .revents = 0,
+            };
+            auto result = ::poll(&pollfd, 1, -1);
+            if (result == 1)
+                continue;
+            if (result < 0)
+                return Error::from_syscall("poll"sv, errno);
+            dbgln("TransportPlan9::transfer: Unexpected poll result {}", result);
+            return Error::from_string_literal("Unexpected poll result");
+        }
+
+        bytes_to_write = bytes_to_write.slice(maybe_nwritten.value());
+    }
+    return {};
+}
+
+TransportPlan9::ShouldShutdown TransportPlan9::read_as_many_messages_as_possible_without_blocking(Function<void(Message&&)>&& callback)
+{
+    auto should_shutdown = ShouldShutdown::No;
+
+    while (is_open()) {
+
+        u8 buffer[4096];
+        auto maybe_bytes_read = m_socket->read_without_waiting({ buffer, sizeof(buffer) });
+
+        if (maybe_bytes_read.is_error()) {
+            auto error = maybe_bytes_read.release_error();
+            if (error.code() == EWOULDBLOCK || error.code() == EAGAIN)
+                break;
+            if (error.code() == ECONNRESET) {
+                should_shutdown = ShouldShutdown::Yes;
+                break;
+            }
+            dbgln("TransportPlan9::read_as_many_messages_as_possible_without_blocking: {}", error);
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+
+        auto bytes_read = maybe_bytes_read.release_value();
+        if (bytes_read.is_empty()) {
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+
+        if (m_unprocessed_bytes.size() + bytes_read.size() > MAX_UNPROCESSED_BUFFER_SIZE) {
+            dbgln("TransportPlan9: Unprocessed buffer would exceed {} bytes, disconnecting peer", MAX_UNPROCESSED_BUFFER_SIZE);
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+        if (m_unprocessed_bytes.try_append(bytes_read.data(), bytes_read.size()).is_error()) {
+            dbgln("TransportPlan9: Failed to append to unprocessed_bytes buffer");
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+    }
+
+    size_t index = 0;
+    while (index + sizeof(MessageHeader) <= m_unprocessed_bytes.size()) {
+        MessageHeader header;
+        memcpy(&header, m_unprocessed_bytes.data() + index, sizeof(MessageHeader));
+        VERIFY(header.payload_size <= MAX_MESSAGE_PAYLOAD_SIZE);
+        VERIFY(header.attachment_count <= MAX_MESSAGE_FD_COUNT);
+        VERIFY(header.attachment_data_size <= MAX_ATTACHMENT_DATA_SIZE);
+
+        Checked<size_t> message_size = header.payload_size;
+        message_size += header.attachment_data_size;
+        message_size += sizeof(MessageHeader);
+        if (message_size.has_overflow() || message_size.value() > m_unprocessed_bytes.size() - index)
+            break;
+        Message message;
+        auto attachment_bytes = ReadonlyBytes { m_unprocessed_bytes.data() + index + sizeof(MessageHeader), header.attachment_data_size };
+        for (u32 attachment_index = 0; attachment_index < header.attachment_count; ++attachment_index)
+            message.attachments.enqueue(deserialize_attachment(attachment_bytes));
+        VERIFY(attachment_bytes.is_empty());
+
+        auto const* payload = m_unprocessed_bytes.data() + index + sizeof(MessageHeader) + header.attachment_data_size;
+        Vector<u8> payload_bytes;
+        if (payload_bytes.try_append(payload, header.payload_size).is_error()) {
+            dbgln("TransportPlan9: Failed to allocate message buffer for payload_size {}", header.payload_size);
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+        message.bytes = ReceivedMessageBytes::from_vector(move(payload_bytes));
+        callback(move(message));
+        Checked<size_t> new_index = index;
+        new_index += header.payload_size;
+        new_index += header.attachment_data_size;
+        new_index += sizeof(MessageHeader);
+        if (new_index.has_overflow()) {
+            dbgln("TransportPlan9: index would overflow");
+            should_shutdown = ShouldShutdown::Yes;
+            break;
+        }
+        index = new_index.value();
+    }
+
+    if (index < m_unprocessed_bytes.size()) {
+        auto remaining_bytes_or_error = ByteBuffer::copy(m_unprocessed_bytes.span().slice(index));
+        if (remaining_bytes_or_error.is_error()) {
+            dbgln("TransportPlan9: Failed to copy remaining bytes");
+            should_shutdown = ShouldShutdown::Yes;
+        } else {
+            m_unprocessed_bytes = remaining_bytes_or_error.release_value();
+        }
+    } else {
+        m_unprocessed_bytes.clear();
+    }
+
+    return should_shutdown;
+}
+
+ErrorOr<TransportHandle> TransportPlan9::release_for_transfer()
+{
+    auto fd = TRY(m_socket->release_fd());
+    return TransportHandle { File::adopt_fd(fd) };
+}
+
+}
