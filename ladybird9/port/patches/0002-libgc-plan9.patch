@@ -36,7 +36,15 @@ public:
         Yes,
     };
 
+#if defined(AK_OS_PLAN9)
+    // Plan 9's segattach length argument is a 32-bit ulong, so a single
+    // demand-paged segment (how reserve_address_space is realized there)
+    // caps just under 4 GiB; 2 GiB is the largest power of two that fits
+    // with the trailing guard page. Same semantics, smaller ceiling.
+    static constexpr size_t default_cage_size = 2ull * GiB;
+#else
     static constexpr size_t default_cage_size = 64ull * GiB;
+#endif
     static_assert(is_power_of_two(default_cage_size));
     static constexpr size_t cage_offset_mask = default_cage_size - 1;
     static constexpr size_t invalid_offset = NumericLimits<size_t>::max();
