+/* gl9: one-shot damage hint. flush_front's full-surface snapshot into the
+ * user buffer is THE per-frame cost on softpipe (2.4MB memcpy at 940x640 —
+ * ~20ms of typing latency in alacritty9). gl9egl knows the damage rect it is
+ * about to ship, sets it here right before its glFinish, and flush_front
+ * copies only that rect. Correctness never depends on the hint: the user
+ * buffer is a staging area and only shipped rects must be fresh. */
+static struct { int x, y, w, h, set; } gl9_damage;
+
+void
+OSMesaGL9SetDamage(int x, int y, int w, int h)
+{
+   gl9_damage.x = x;
+   gl9_damage.y = y;
+   gl9_damage.w = w;
+   gl9_damage.h = h;
+   gl9_damage.set = 1;
+}
+
+void
+OSMesaGL9ClearDamage(void)
+{
+   gl9_damage.set = 0;
+}
+
 /* Reads the color or depth buffer from the backing context to either the user storage
