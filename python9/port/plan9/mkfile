# mkfile — CPython 3.11 for 9front/amd64 (APE/pcc).
#
# SKELETON — not yet runnable. Blocked on the wchar shim (obstacle 3 in
# README.md). This documents the intended hand-authored build that replaces
# autoconf+make. Run inside the VM from the source-tree root with `mk`.
#
# Compiler: pcc (APE). Every translation unit needs the POSIX feature macro and
# the core-build define; some will additionally need _BSD_EXTENSION.

</objtype/mkfile

CC=pcc
CFLAGS=-D_POSIX_SOURCE -DPy_BUILD_CORE -I. -IInclude -IInclude/internal -Iport/plan9/ape-shim

# Minimal first-light object set (grow as files compile clean). The full build
# enumerates Objects/ Python/ Parser/ + the static Modules/ from Setup.
OBJS=\
	Objects/boolobject.$O\

all:V: $OBJS
	echo 'first-light objects built'

%.$O: %.c
	$CC $CFLAGS -c $stem.c -o $stem.$O

clean:V:
	rm -f */*.$O
