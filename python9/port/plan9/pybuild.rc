#!/bin/rc
# pybuild.rc -- compile one CPython source file under APE/pcc in the VM.
# Invoked as: rc /usr/glenda/pybuild.rc Objects/boolobject.c >/tmp/cc.log >[2=1]
# Keeps the long pcc command server-side so the listen1 channel only ever sees
# a short invocation (long lines get dropped over listen1 on the slow VM).
R=/usr/glenda/Python-3.11.14
SHIM=/usr/glenda/apeshim
o=/tmp/out.o
pcc -c -D_POSIX_SOURCE -D_BSD_EXTENSION '-Dclockid_t=int' -DPy_BUILD_CORE -I$SHIM -I$R -I$R/Include -I$R/Include/internal $R/$1 -o $o
echo pybuild done rc $status
