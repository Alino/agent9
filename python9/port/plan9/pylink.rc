#!/bin/rc
# pylink.rc -- compile every source in /usr/glenda/link_srcs.txt to /tmp/obj and
# link a `python` binary (APE/pcc). Long-running on TCG. Watch /tmp/build.log.
R=/usr/glenda/Python-3.11.14
SHIM=/usr/glenda/apeshim
mkdir -p /tmp/obj
echo build start >/tmp/build.log
for(src in `{cat /usr/glenda/link_srcs.txt}){
	o=/tmp/obj/^`{basename $src .c}^.o
	pcc -c -D_POSIX_SOURCE -D_BSD_EXTENSION '-Dclockid_t=int' -DPy_BUILD_CORE -I$SHIM -I$R -I$R/Include -I$R/Include/internal $R/$src -o $o >>/tmp/build.log >[2=1]
	if(test -f $o)
		echo ok $src >>/tmp/build.log
	if not
		echo FAIL $src >>/tmp/build.log
}
echo COMPILE-DONE >>/tmp/build.log
pcc -o /tmp/python /tmp/obj/*.o >>/tmp/build.log >[2=1]
echo LINK-DONE rc $status >>/tmp/build.log
ls -l /tmp/python >>/tmp/build.log >[2=1]
