.DS_Store
__pycache__/
*.pyc

# Release artifacts — too big for git, shipped via GitHub Releases
release/*.qcow2
release/*.tar.gz
release/*.zip
release/agent9-v*

# Plan 9 build artifacts
*.6
*.5
*.8
6.out
8.out
[0-9].out

# macOS / cross-compile artifacts (used during dev, never committed)
*.dSYM/
src/vts/test/bin/
src/pi9/pi9
src/pi9/pi9.linux.*
src/pi9/pi9.plan9.*
src/pi9/pi9.darwin.*

# Stray dev scratch
src/_restore-9front-vt/

# python9: vendored CPython source + host build are large/derived. The harness
# scripts and the parity manifests (the scoreboard) ARE committed.
python9/cpython/src/
python9/cpython/host-build/
python9/parity/manifests/*.tmp.json
# python9 cc9 profile (port/cc9/): same rule — build output and fetched upstream
# stay out, the build script + config headers are committed. deps/ holds the
# pinned tarballs build.py expects extracted there: zlib-1.3.1 and
# sqlite-amalgamation-3460100.
python9/port/cc9/_out/
python9/port/cc9/deps/
python9/release/stage/
python9/release/*.tar.gz

# Local-only secrets and dev scratch
.env
.env.*
*.token
*.key
auth.json
