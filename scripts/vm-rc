#!/usr/bin/env bash
# vm-rc - run rc commands in the 9front VM via aux/listen1 on host :1717.
#
# Quirks of the channel:
#   - rc redirect is `>[2]/dev/null`, NOT `2>/dev/null`.
#   - `command1 && command2 && command3` returns only the LAST line of
#     stdout for some reason — split with `;` if you need each step's
#     output, or just send them as separate vm-rc calls.
#   - The connection closes after the command finishes — `nc` returns
#     immediately on EOF.
#
# Usage:
#   vm-rc 'date'                   # single command
#   echo 'cmd' | vm-rc -           # read from stdin
#
# Env: VM_TIMEOUT=N to override the nc -w default (30s).
set -u
TIMEOUT="${VM_TIMEOUT:-30}"
if [ "${1:-}" = "-" ]; then
  exec nc -w "$TIMEOUT" 127.0.0.1 1717
fi
CMD="$*"
if [ -z "$CMD" ]; then
  echo "usage: vm-rc 'command'   |   vm-rc -   (read stdin)" >&2
  exit 2
fi
printf '%s\n' "$CMD" | nc -w "$TIMEOUT" 127.0.0.1 1717
