#!/bin/bash
# n9link — link objects/archives into a 9front a.out.
#   n9link -o OUT.aout obj1.o ... [lib1.a ...]
# Mirrors cc9/host/cc9's link step (lld -T plan9.ld, runtime+libm start-group,
# elf2aout).
set -euo pipefail
AGENT9="$(cd "$(dirname "$0")/../.." && pwd)"
CC9="$AGENT9/cc9"
LLD="${CC9_LLD:-$(brew --prefix lld)/bin/ld.lld}"
LIB="$CC9/lib/libcc9cxx.a"; LIBM="$CC9/lib/libcc9m.a"; LDS="$CC9/test/plan9.ld"
out=""; args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -o) out="$2"; shift 2 ;;
    *) args+=("$1"); shift ;;
  esac
done
[ -n "$out" ] || { echo "usage: n9link -o OUT.aout objs/archives..."; exit 2; }
elf="${out%.aout}.elf"
"$LLD" -o "$elf" "${args[@]}" --start-group "$LIB" "$LIBM" --end-group \
  -T "$LDS" -static -nostdlib
python3 "$CC9/host/elf2aout.py" "$elf" "$out" >&2
