+#ifdef __plan9__
+// Plan 9 has no dlopen; the bundled parsers are linked in statically and
+// resolved from this table by their tree_sitter_<symbol> name.
+#define TS_STATIC_LANG(sym) extern TSLanguage *tree_sitter_##sym(void);
+TS_STATIC_LANG(c)
+TS_STATIC_LANG(lua)
+TS_STATIC_LANG(vim)
+TS_STATIC_LANG(vimdoc)
+TS_STATIC_LANG(query)
+TS_STATIC_LANG(markdown)
+TS_STATIC_LANG(markdown_inline)
+static const struct { const char *name; TSLanguage *(*fn)(void); } ts_static_langs[] = {
+  { "c", tree_sitter_c }, { "lua", tree_sitter_lua }, { "vim", tree_sitter_vim },
+  { "vimdoc", tree_sitter_vimdoc }, { "query", tree_sitter_query },
+  { "markdown", tree_sitter_markdown }, { "markdown_inline", tree_sitter_markdown_inline },
+};
+
+static const TSLanguage *load_language_from_object(lua_State *L, const char *path,
+                                                   const char *lang_name, const char *symbol)
+{
+  for (size_t i = 0; i < ARRAY_SIZE(ts_static_langs); i++) {
+    if (strcmp(ts_static_langs[i].name, symbol) == 0) {
+      return ts_static_langs[i].fn();
+    }
+  }
+  luaL_error(L, "Failed to load parser for language '%s': no dlopen on Plan 9 "
+             "and '%s' is not linked in", lang_name, symbol);
+  return NULL;
+}
