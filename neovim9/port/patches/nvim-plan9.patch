diff --git a/runtime/lua/netrw_fastlist.lua b/runtime/lua/netrw_fastlist.lua
new file mode 100644
index 0000000..55b7c17
--- /dev/null
+++ b/runtime/lua/netrw_fastlist.lua
@@ -0,0 +1,52 @@
+-- netrw_fastlist — one-pass local directory listing for netrw.
+-- nvim-plan9: netrw's s:NetrwLocalListingList classifies every entry with
+-- ~4 stat-class vimscript calls plus ~30 interpreted lines — ~8ms/file on a
+-- slow CPU (2.5s for a 300-file directory). This does the same work in one
+-- lua pass (~0.3ms/file). Only the default shapes go through here (thin and
+-- wide listings, sort-by-name); netrw falls back to its own loop otherwise.
+local M = {}
+
+local band = bit.band
+
+function M.list(dirname)
+  local uv = vim.uv
+  local sep = dirname:sub(-1) == '/' and '' or '/'
+  -- '.' and '..' first, exactly like netrw's readdir prelude; both are
+  -- always directories.
+  local out = { './', '../' }
+  local fs = uv.fs_scandir(dirname)
+  if not fs then
+    return out
+  end
+  while true do
+    local name, t = uv.fs_scandir_next(fs)
+    if not name then
+      break
+    end
+    local st
+    if t == nil or t == 'file' then
+      -- need the mode for the executable '*' marker (and the type at all
+      -- when scandir doesn't provide one)
+      st = uv.fs_lstat(dirname .. sep .. name)
+      if st then
+        t = st.type
+      end
+    end
+    if t == 'link' then
+      out[#out + 1] = name .. '@'
+    elseif t == 'socket' then
+      out[#out + 1] = name .. '='
+    elseif t == 'fifo' then
+      out[#out + 1] = name .. '|'
+    elseif t == 'directory' then
+      out[#out + 1] = name .. '/'
+    elseif st and band(st.mode, 73) ~= 0 then -- 0111: executable by anyone
+      out[#out + 1] = name .. '*'
+    else
+      out[#out + 1] = name
+    end
+  end
+  return out
+end
+
+return M
