+#ifdef __plan9__
+// No SIGWINCH on Plan 9. alacritty9 publishes the live size as the /env/LINES
+// and /env/COLS files (updated on every resize); poll them and raise(SIGWINCH)
+// into cc9's handler table, which feeds libuv's normal signal machinery.
+# include <pthread.h>
+static int tui_plan9_env_num(const char *path)
+{
+  FILE *f = fopen(path, "r");
+  if (f == NULL) {
+    return 0;
+  }
+  int v = 0;
+  int c;
+  while ((c = fgetc(f)) >= '0' && c <= '9') {
+    v = v * 10 + (c - '0');
+  }
+  fclose(f);
+  return v;
+}
+static void *tui_plan9_winch_poller(void *arg)
+{
+  (void)arg;
+  int rows = tui_plan9_env_num("/env/LINES");
+  int cols = tui_plan9_env_num("/env/COLS");
+  while (true) {
+    uv_sleep(300);
+    int r = tui_plan9_env_num("/env/LINES");
+    int c = tui_plan9_env_num("/env/COLS");
+    if (r > 0 && c > 0 && (r != rows || c != cols)) {
+      rows = r;
+      cols = c;
+      raise(SIGWINCH);
+    }
+  }
+  return NULL;
+}
+void tui_plan9_winch_poller_start(void)
+{
+  pthread_t t;
+  if (pthread_create(&t, NULL, tui_plan9_winch_poller, NULL) == 0) {
+    pthread_detach(t);
+  }
+}
+#endif
